@model IEnumerable<SportsShoesEcommerce.Models.ApplicationUser>

@{
    ViewData["Title"] = "Users Management";
    Layout = "_AdminLayout";
    var userRoles = ViewBag.UserRoles as Dictionary<string, string>;
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800 font-weight-bold">Users Management</h1>
</div>

<form method="get" asp-action="Index" class="bg-white p-3 rounded shadow-sm mb-4 border-left-dark">
    <div class="row align-items-end">

        <div class="form-group col-md-5 mb-2 mb-md-0">
            <label class="small font-weight-bold text-muted">Select User</label>
            <select name="selectedUserId" asp-items="ViewBag.UsersDropdown" class="form-control form-control-sm">
                <option value="">All Users</option>
            </select>
        </div>

        <div class="form-group col-md-4 mb-2 mb-md-0">
            <label class="small font-weight-bold text-muted">Filter by Role</label>
            <select name="selectedRole" class="form-control form-control-sm">
                <option value="">All Roles</option>
                @foreach (var role in ViewBag.RolesList as List<string>)
                {
                    <option value="@role" selected="@(ViewData["CurrentSelectedRole"]?.ToString() == role)">@role</option>
                }
            </select>
        </div>

        <div class="form-group col-md-3 mb-0 text-right">
            <button type="submit" class="btn btn-dark btn-sm px-3 font-weight-bold shadow-sm"><i class="fas fa-filter mr-1"></i> Filter</button>
            <a asp-action="Index" class="btn btn-secondary btn-sm px-3 font-weight-bold shadow-sm"><i class="fas fa-undo mr-1"></i> Reset</a>
        </div>
    </div>
</form>

<div class="card shadow mb-4 border-left-dark">
    <div class="card-header py-3 bg-light">
        <h6 class="m-0 font-weight-bold text-dark"><i class="fas fa-users mr-2"></i>Registered Users</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover table-bordered" id="usersTable" width="100%" cellspacing="0">
                <thead class="thead-light text-center">
                    <tr>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Role</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        var displayRole = userRoles != null && userRoles.ContainsKey(user.Id) ? userRoles[user.Id] : "No Role";
                        <tr>
                            <td class="align-middle font-weight-bold text-dark">@user.FullName</td>
                            <td class="align-middle">@user.Email</td>
                            <td class="text-center align-middle">
                                <span class="badge @(displayRole == "Admin" ? "badge-danger" : "badge-primary") px-3 py-2">
                                    @displayRole
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#usersTable').DataTable();
        });
    </script>
}