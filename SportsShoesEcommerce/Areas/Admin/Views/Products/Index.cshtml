@model IEnumerable<SportsShoesEcommerce.Models.Product>

@{
    ViewData["Title"] = "Products Inventory";
    Layout = "_AdminLayout";
    var currentDate = DateTime.Now;
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800 font-weight-bold">Products Management</h1>
</div>

<form method="get" asp-action="Index" class="bg-white p-3 rounded shadow-sm mb-4 border-left-primary">
    <div class="row align-items-end">

        <div class="form-group col-md-3 mb-2 mb-md-0">
            <label class="small font-weight-bold text-muted">Gender</label>
            <select name="gender" class="form-control form-control-sm">
                <option value="">All Genders</option>
                <option value="Men" selected="@(ViewData["CurrentGender"]?.ToString() == "Men")">Men</option>
                <option value="Women" selected="@(ViewData["CurrentGender"]?.ToString() == "Women")">Women</option>
                <option value="Unisex" selected="@(ViewData["CurrentGender"]?.ToString() == "Unisex")">Unisex</option>
                <option value="Kids" selected="@(ViewData["CurrentGender"]?.ToString() == "Kids")">Kids</option>
            </select>
        </div>

        <div class="form-group col-md-2 mb-2 mb-md-0">
            <label class="small font-weight-bold text-muted">Brand</label>
            <select name="brandId" asp-items="ViewBag.BrandId" class="form-control form-control-sm">
                <option value="">All Brands</option>
            </select>
        </div>

        <div class="form-group col-md-2 mb-2 mb-md-0">
            <label class="small font-weight-bold text-muted">Category</label>
            <select name="categoryId" asp-items="ViewBag.CategoryId" class="form-control form-control-sm">
                <option value="">All Categories</option>
            </select>
        </div>

        <div class="form-group col-md-2 mb-2 mb-md-0">
            <label class="small font-weight-bold text-muted">Stock Status</label>
            <select name="stockStatus" class="form-control form-control-sm">
                <option value="">All Statuses</option>
                <option value="InStock" selected="@(ViewData["CurrentStockStatus"]?.ToString() == "InStock")">In Stock</option>
                <option value="OutOfStock" selected="@(ViewData["CurrentStockStatus"]?.ToString() == "OutOfStock")">Out of Stock</option>
            </select>
        </div>

        <div class="form-group col-md-3 mb-0 text-right">
            <button type="submit" class="btn btn-primary btn-sm px-3 font-weight-bold shadow-sm"><i class="fas fa-filter mr-1"></i> Filter</button>
            <a asp-action="Index" class="btn btn-secondary btn-sm px-3 font-weight-bold shadow-sm"><i class="fas fa-undo mr-1"></i> Reset</a>
        </div>
    </div>
</form>

<div class="card shadow mb-4 border-left-primary">
    <div class="card-header py-3 d-flex justify-content-between align-items-center bg-light">
        <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-boxes mr-2"></i>Full Inventory</h6>
        <a asp-area="Admin" asp-controller="Products" asp-action="Create" class="btn btn-primary btn-icon-split shadow-sm">
            <span class="icon text-white-50"><i class="fas fa-plus"></i></span>
            <span class="text">Add New Product</span>
        </a>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover table-bordered" id="dataTable" width="100%" cellspacing="0">
                <thead class="thead-light text-center">
                    <tr>
                        <th style="width: 80px;">Image</th>
                        <th>Product Name</th>
                        <th>Price</th>
                        <th>Brand</th>
                        <th>Category</th>
                        <th style="width: 220px;">Stock Control</th>
                        <th style="width: 150px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center align-middle">
                                @if (item.ProductImages != null && item.ProductImages.Any())
                                {
                                    var firstImage = item.ProductImages.FirstOrDefault()?.ImagePath;
                                    <img src="~/images/products/@firstImage" width="50" height="50" class="rounded shadow-sm border" style="object-fit:cover" />
                                }
                                else
                                {
                                    <div class="rounded bg-gray-200 d-flex align-items-center justify-content-center mx-auto shadow-sm" style="width: 50px; height: 50px;">
                                        <i class="fas fa-shoe-prints text-gray-400 small"></i>
                                    </div>
                                }
                            </td>
                            <td class="align-middle font-weight-bold text-dark">@item.Name</td>

                            <td class="align-middle text-center font-weight-bold">
                                @if (item.Discounts != null && item.Discounts.Any(d => d.IsActive && d.StartDate <= currentDate && d.EndDate >= currentDate))
                                {
                                    var activeDiscount = item.Discounts.First(d => d.IsActive && d.StartDate <= currentDate && d.EndDate >= currentDate);
                                    decimal priceBeforeDiscount = item.Price / (1 - (activeDiscount.DiscountPercentage / 100m));

                                    <div>
                                        <span class="text-muted small font-weight-bold" style="text-decoration: line-through; font-style: italic; opacity: 0.7;">
                                            $@priceBeforeDiscount.ToString("F2")
                                        </span>
                                    </div>
                                    <div class="text-danger">
                                        $@item.Price.ToString("F2")
                                        <div style="font-size: 0.7rem;" class="badge badge-danger p-1 mt-1">@activeDiscount.DiscountPercentage% OFF</div>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-success">$@item.Price.ToString("F2")</span>
                                }
                            </td>

                            <td class="align-middle text-center"><span class="badge badge-light border px-2 py-1">@item.Brand?.Name</span></td>
                            <td class="align-middle text-center text-primary">@item.Category?.Name</td>

                            <td class="align-middle p-2 bg-light">
                                <div class="mb-2 text-right">
                                    <button class="btn btn-outline-primary btn-sm py-0 px-1 font-weight-bold" style="font-size:0.8rem;" data-toggle="modal" data-target="#addVariantModal-@item.Id">
                                        <i class="fas fa-plus-circle mr-1"></i> Add Variant
                                    </button>
                                </div>
                                @if (item.ProductVariants != null && item.ProductVariants.Any())
                                {
                                    foreach (var variant in item.ProductVariants)
                                    {
                                        <form asp-area="Admin" asp-controller="Products" asp-action="UpdateStock" method="post" class="d-flex align-items-center justify-content-between mb-1 pb-1 border-bottom">
                                            <input type="hidden" name="variantId" value="@variant.Id" />
                                            <span class="text-muted small font-weight-bold">Size @variant.Size (@variant.Color):</span>

                                            <div class="input-group input-group-sm" style="max-width: 90px;">
                                                <input type="number" name="quantity" value="@variant.StockQuantity" class="form-control text-center font-weight-bold border-primary p-0" min="0" />
                                                <div class="input-group-append">
                                                    <button type="submit" class="btn btn-primary px-1" title="Update"><i class="fas fa-save" style="font-size:0.75rem;"></i></button>
                                                </div>
                                            </div>
                                        </form>
                                    }
                                }
                                else
                                {
                                    <div class="text-center text-muted small py-1">No variants yet.</div>
                                }
                            </td>

                            <td class="text-center align-middle">
                                <div class="btn-group" role="group">
                                    <a asp-area="Admin" asp-controller="Products" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-info btn-circle btn-sm shadow-sm"><i class="fas fa-edit"></i></a>
                                    <a asp-area="Admin" asp-controller="Products" asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary btn-circle btn-sm shadow-sm"><i class="fas fa-info-circle"></i></a>
                                    <a asp-area="Admin" asp-controller="Products" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-circle btn-sm shadow-sm"><i class="fas fa-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@foreach (var item in Model)
{
    <div class="modal fade" id="addVariantModal-@item.Id" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm" role="document">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-light py-2">
                    <h6 class="modal-title font-weight-bold text-gray-800">Add Variant</h6>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                </div>
                <form asp-area="Admin" asp-controller="Products" asp-action="AddVariant" method="post" class="m-0">
                    <div class="modal-body py-2">
                        <input type="hidden" name="productId" value="@item.Id" />
                        <div class="form-group mb-2">
                            <label class="small font-weight-bold mb-1">Size</label>
                            <input name="size" class="form-control form-control-sm" placeholder="e.g. 42" required />
                        </div>
                        <div class="form-group mb-2">
                            <label class="small font-weight-bold mb-1">Color</label>
                            <input name="color" class="form-control form-control-sm" placeholder="e.g. Black" required />
                        </div>
                        <div class="form-group mb-0">
                            <label class="small font-weight-bold mb-1">Stock Quantity</label>
                            <input name="stockQuantity" type="number" class="form-control form-control-sm" min="0" placeholder="e.g. 50" required />
                        </div>
                    </div>
                    <div class="modal-footer bg-light py-1">
                        <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-primary btn-sm">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#dataTable').DataTable();
        });
    </script>
}