@using SportsShoesEcommerce.Models.Enums
@model SportsShoesEcommerce.Models.Product

@{
    ViewData["Title"] = "Create Product";
    Layout = "_AdminLayout";
}

<div class="card shadow mb-4 border-left-primary">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-plus-square mr-2"></i>Create New Product</h6>
    </div>
    <div class="card-body">
        <form asp-area="Admin" asp-controller="Products" asp-action="Create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row">
                <div class="col-md-8">
                    <div class="form-group">
                        <label asp-for="Name" class="control-label font-weight-bold">Product Name</label>
                        <input asp-for="Name" class="form-control" placeholder="Enter product name..." />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="Price" class="control-label font-weight-bold">Price ($)</label>
                        <input asp-for="Price" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Description" class="control-label font-weight-bold">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Tell us more about the shoes..."></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="CategoryId" class="control-label font-weight-bold">Category</label>
                        <select asp-for="CategoryId" class="form-control" asp-items="@(ViewData["CategoryId"] as SelectList)">
                            <option value="">-- Select Category --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="BrandId" class="control-label font-weight-bold">Brand</label>
                        <select asp-for="BrandId" class="form-control" asp-items="@(ViewData["BrandId"] as SelectList)">
                            <option value="">-- Select Brand --</option>
                        </select>
                        <span asp-validation-for="BrandId" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label asp-for="Gender" class="control-label font-weight-bold">Gender</label>
                        <select asp-for="Gender" class="form-control" asp-items="Html.GetEnumSelectList<SportsShoesEcommerce.Models.Enums.Gender>()"></select>
                        <span asp-validation-for="Gender" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <hr class="my-4" />

            <div class="row">
                <div class="col-md-12">
                    <div class="form-group border p-3 bg-light rounded shadow-sm">
                        <label class="control-label font-weight-bold text-success">
                            <i class="fas fa-images mr-1"></i> Upload Product Images
                        </label>
                        <input type="file" name="imageFiles" class="form-control-file" multiple required />
                        <small class="text-muted d-block mt-1">You can select multiple photos. The first one will be the main.</small>
                    </div>
                </div>
            </div>

            <h4 class="h5 text-primary font-weight-bold mt-4"><i class="fas fa-layer-group mr-2"></i> Initial Product Variant (Stock)</h4>
            <div class="row bg-light p-3 rounded mb-4 mx-0 border">
                <div class="form-group col-md-3">
                    <label class="control-label font-weight-bold">Size</label>
                    <input name="Size" class="form-control" placeholder="e.g. 42" required />
                </div>
                <div class="form-group col-md-3">
                    <label class="control-label font-weight-bold">Color</label>
                    <input name="Color" class="form-control" placeholder="e.g. Black" required />
                </div>
                <div class="form-group col-md-3">
                    <label class="control-label font-weight-bold">Initial Stock Quantity</label>
                    <input name="StockQuantity" type="number" class="form-control" min="0" placeholder="e.g. 50" required />
                </div>
                <div class="form-group col-md-3">
                    <label class="control-label font-weight-bold">SKU Code</label>
                    <input name="SKU" class="form-control" placeholder="e.g. NIKE-BLK-42" required />
                </div>
            </div>

            <div class="form-group mt-4 pt-2">
                <button type="submit" class="btn btn-primary btn-lg btn-block shadow">
                    <i class="fas fa-save mr-2"></i> Create Product
                </button>
            </div>
        </form>
    </div>
</div>

<div class="mb-4">
    <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="btn btn-secondary btn-sm shadow-sm">
        <i class="fas fa-arrow-left mr-1"></i> Back to List
    </a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}