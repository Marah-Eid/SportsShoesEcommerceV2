@using SportsShoesEcommerce.Models.Enums
@model SportsShoesEcommerce.Models.Product

@{
    ViewData["Title"] = "Edit Product";
    Layout = "_AdminLayout";
    var brandList = ViewBag.BrandId as SelectList;
    var categoryList = ViewBag.CategoryId as SelectList;
}

<div class="card shadow mb-4 border-left-success">
    <div class="card-header py-3 d-flex justify-content-between align-items-center bg-light">
        <h6 class="m-0 font-weight-bold text-success"><i class="fas fa-edit mr-2"></i>Edit Product: @Model.Name</h6>
        <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="btn btn-secondary btn-sm shadow-sm">
            <i class="fas fa-arrow-left fa-sm mr-1"></i> Back to List
        </a>
    </div>
    <div class="card-body">
        <form asp-area="Admin" asp-controller="Products" asp-action="Edit" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            @* الحقول المخفية الأساسية *@
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedAt" />
            <input type="hidden" asp-for="BrandId" />

            <div class="row">
                <div class="col-md-8">
                    <div class="form-group mb-3">
                        <label asp-for="Name" class="control-label font-weight-bold">Product Name</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="Price" class="control-label font-weight-bold">Price ($)</label>
                        <input asp-for="Price" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Description" class="control-label font-weight-bold">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="CategoryId" class="control-label font-weight-bold">Category</label>
                        <select asp-for="CategoryId" class="form-control" asp-items="categoryList"></select>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Gender" class="control-label font-weight-bold">Gender</label>
                        <select asp-for="Gender" class="form-control" asp-items="Html.GetEnumSelectList<Gender>()"></select>
                    </div>
                </div>
            </div>

            <hr class="my-4" />

            <div class="row">
                <div class="col-md-12">
                    <div class="form-group border p-3 bg-light rounded shadow-sm">
                        <label class="control-label font-weight-bold d-block text-primary">
                            <i class="fas fa-images mr-1"></i> Current Product Gallery
                        </label>

                        <div class="d-flex flex-wrap mb-3">
                            @if (Model.ProductImages != null && Model.ProductImages.Any())
                            {
                                foreach (var img in Model.ProductImages)
                                {
                                    <div class="position-relative m-2">
                                        <img src="~/images/products/@img.ImagePath" class="img-thumbnail" style="height: 120px; width: 120px; object-fit: cover;" />
                                        @if (img.IsMain)
                                        {
                                            <span class="badge badge-primary position-absolute" style="top: 5px; left: 5px;">Main</span>
                                        }
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-muted p-3">No images uploaded yet.</div>
                            }
                        </div>

                        <label class="font-weight-bold mt-2 text-success"><i class="fas fa-plus-circle mr-1"></i> Add More Images</label>
                        @* تم تغيير الاسم إلى imageFiles وإضافة multiple *@
                        <input type="file" name="imageFiles" class="form-control-file" multiple accept="image/*" />
                        <small class="text-muted d-block mt-2 font-italic">New images will be added to the existing ones.</small>
                    </div>
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-md-12">
                    <div class="custom-control custom-switch text-center">
                        <input type="checkbox" asp-for="IsDeleted" class="custom-control-input" id="isDeletedCheck">
                        <label class="custom-control-label font-weight-bold text-danger" for="isDeletedCheck" style="cursor: pointer;">
                            Archive this product (Hide from customers)
                        </label>
                    </div>
                </div>
            </div>
            <h4 class="h5 text-primary font-weight-bold mt-4"><i class="fas fa-boxes mr-2"></i> Edit All Variants & Stock Levels</h4>
            <div class="bg-light p-3 rounded mb-4 border">
                @if (Model.ProductVariants != null && Model.ProductVariants.Any())
                {
                    <div class="row font-weight-bold text-muted small mb-2 text-center d-none d-md-flex">
                        <div class="col-md-3">Size</div>
                        <div class="col-md-3">Color</div>
                        <div class="col-md-3">Stock Quantity</div>
                        <div class="col-md-3">SKU Code (Read Only)</div>
                    </div>

                    @foreach (var variant in Model.ProductVariants)
                    {
                        <div class="row mb-2 align-items-center bg-white p-2 rounded shadow-sm border mx-0">
                            <div class="form-group col-md-3 mb-0">
                                <input name="VariantSizes[@variant.Id]" value="@variant.Size" class="form-control form-control-sm text-center font-weight-bold" required />
                            </div>
                            <div class="form-group col-md-3 mb-0">
                                <input name="VariantColors[@variant.Id]" value="@variant.Color" class="form-control form-control-sm text-center" required />
                            </div>
                            <div class="form-group col-md-3 mb-0">
                                <input name="VariantQuantities[@variant.Id]" type="number" value="@variant.StockQuantity" class="form-control form-control-sm text-center font-weight-bold border-primary" min="0" required />
                            </div>
                            <div class="form-group col-md-3 mb-0">
                                <input class="form-control form-control-sm text-center bg-light" value="@variant.SKU" readonly />
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center text-muted py-2 small">No variants found for this product. You can add them from the main inventory dashboard.</div>
                }
            </div>

            <div class="form-group mt-5">
                <button type="submit" class="btn btn-success btn-lg btn-block shadow">
                    <i class="fas fa-save mr-2"></i> Update Product & Gallery
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}