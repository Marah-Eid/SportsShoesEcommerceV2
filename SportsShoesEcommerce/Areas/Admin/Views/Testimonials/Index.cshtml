@model IEnumerable<SportsShoesEcommerce.Models.Testimonial>

@{
    ViewData["Title"] = "Testimonials Management";
    Layout = "_AdminLayout"; // تأكد من ربطه بالثيم الخاص بك
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800 font-weight-bold">Website Testimonials</h1>
</div>

<div class="card shadow mb-4 border-left-info">
    <div class="card-header py-3 d-flex justify-content-between align-items-center bg-light">
        <h6 class="m-0 font-weight-bold text-info"><i class="fas fa-quote-left mr-2"></i>User Feedback</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover table-bordered" id="dataTable" width="100%" cellspacing="0">
                <thead class="thead-light text-center">
                    <tr>
                        <th>User</th>
                        <th>Content</th>
                        <th>Rating</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th style="width: 180px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="align-middle">@item.User?.Email</td>
                            <td class="align-middle">
                                <small class="text-dark">"@item.Content"</small>
                            </td>
                            <td class="text-center align-middle">
                                @for (int i = 0; i < item.Rating; i++)
                                {
                                    <i class="fas fa-star text-warning small"></i>
                                }
                            </td>
                            <td class="text-center align-middle">
                                @if (item.IsApproved)
                                {
                                    <span class="badge badge-success px-2 py-1"><i class="fas fa-check-circle mr-1"></i>Approved</span>
                                }
                                else
                                {
                                    <span class="badge badge-warning px-2 py-1 text-dark"><i class="fas fa-clock mr-1"></i>Pending</span>
                                }
                            </td>
                            <td class="align-middle text-center small">
                                @item.CreatedAt.ToString("yyyy-MM-dd")
                            </td>
                            <td class="text-center align-middle">
                                <div class="btn-group" role="group">
                                    @if (!item.IsApproved)
                                    {
                                        <form asp-action="Approve" asp-route-id="@item.Id" method="post" class="d-inline mr-1">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-success btn-sm shadow-sm" title="Approve">
                                                <i class="fas fa-check"></i> Approve
                                            </button>
                                        </form>
                                    }
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-circle btn-sm shadow-sm mr-1" title="Details">
                                        <i class="fas fa-info-circle"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-circle btn-sm shadow-sm" title="Delete">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>