@model IEnumerable<SportsShoesEcommerce.Models.Order>

@{
    ViewData["Title"] = "Orders Management";
}

<div class="container-fluid px-4 py-4">
    <div class="d-sm-flex align-items-center justify-content-between mb-4 bg-white p-3 rounded shadow-sm">
        <div>
            <h1 class="h3 mb-0 text-gray-800 font-weight-bold">Orders Management</h1>
        </div>
        <div>
            <form asp-action="CreateTestOrder" method="post" class="m-0">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-warning btn-sm font-weight-bold shadow-sm">
                    <i class="fas fa-plus-circle mr-1"></i> Add Test Order
                </button>
            </form>
        </div>
    </div>

    <form method="get" asp-action="Index" class="bg-white p-3 rounded shadow-sm mb-4 border-left-success">
        <div class="row align-items-end">
            <div class="form-group col-md-3 mb-2 mb-md-0">
                <label class="small font-weight-bold text-muted">Order Status</label>
                <select name="orderStatus" class="form-control form-control-sm">
                    <option value="">All Statuses</option>
                    @foreach (var status in Enum.GetValues(typeof(SportsShoesEcommerce.Models.Enums.OrderStatus)))
                    {
                        <option value="@status" selected="@(ViewData["CurrentStatus"]?.ToString() == status.ToString())">@status</option>
                    }
                </select>
            </div>
            <div class="form-group col-md-3 mb-2 mb-md-0">
                <label class="small font-weight-bold text-muted">From Date</label>
                <input type="date" name="startDate" value="@ViewData["StartDate"]" class="form-control form-control-sm" />
            </div>
            <div class="form-group col-md-3 mb-2 mb-md-0">
                <label class="small font-weight-bold text-muted">To Date</label>
                <input type="date" name="endDate" value="@ViewData["EndDate"]" class="form-control form-control-sm" />
            </div>
            <div class="form-group col-md-3 mb-0 text-right">
                <button type="submit" class="btn btn-success btn-sm px-3 font-weight-bold shadow-sm"><i class="fas fa-search mr-1"></i> Search</button>
                <a asp-action="Index" class="btn btn-secondary btn-sm px-3 font-weight-bold shadow-sm"><i class="fas fa-undo mr-1"></i> Reset</a>
            </div>
        </div>
    </form>

    <div class="card shadow mb-4 border-0 rounded">
        <div class="card-header py-3 bg-white d-flex align-items-center justify-content-between border-bottom">
            <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-boxes mr-2"></i> All Orders Placed</h6>
        </div>
        <div class="card-body bg-white">
            <div class="table-responsive">
                <table class="table table-bordered table-hover bg-white m-0" id="dataTable" width="100%" cellspacing="0">
                    <thead class="bg-light text-gray-700 text-center">
                        <tr>
                            <th style="width: 10%;">Order ID</th>
                            <th style="width: 30%;">Customer Email</th>
                            <th style="width: 20%;">Order Status</th>
                            <th style="width: 20%;">Details</th>
                            <th style="width: 20%;">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="text-center text-gray-800 align-middle">
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="align-middle font-weight-bold">#@item.Id</td>
                                <td class="align-middle text-primary">@item.User?.Email</td>
                                <td class="align-middle">
                                    @if (item.OrderStatus.ToString() == "Pending")
                                    {
                                        <span class="badge badge-warning px-3 py-2 text-white shadow-sm" style="border-radius: 4px; font-size: 0.85rem;">Pending</span>
                                    }
                                    else if (item.OrderStatus.ToString() == "Processing")
                                    {
                                        <span class="badge badge-info px-3 py-2 shadow-sm" style="border-radius: 4px; font-size: 0.85rem;">Processing</span>
                                    }
                                    else if (item.OrderStatus.ToString() == "Completed")
                                    {
                                        <span class="badge badge-success px-3 py-2 shadow-sm" style="border-radius: 4px; font-size: 0.85rem;">Completed</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger px-3 py-2 shadow-sm" style="border-radius: 4px; font-size: 0.85rem;">Cancelled</span>
                                    }
                                </td>
                                <td class="align-middle">
                                    <button class="btn btn-outline-secondary btn-sm px-3 font-weight-bold" data-toggle="modal" data-target="#orderModal-@item.Id">
                                        <i class="fas fa-eye mr-1"></i> View Items
                                    </button>
                                </td>
                                <td class="align-middle">
                                    <div class="d-flex align-items-center justify-content-center">
                                        <form asp-action="UpdateStatus" method="post" class="m-0 mr-2">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <div class="input-group input-group-sm" style="max-width: 180px;">
                                                <select name="status" class="custom-select form-control font-weight-bold text-gray-700 border-primary">
                                                    <option value="Pending">Pending</option>
                                                    <option value="Processing">Processing</option>
                                                    <option value="Completed">Completed</option>
                                                    <option value="Cancelled">Cancelled</option>
                                                </select>
                                                <div class="input-group-append">
                                                    <button type="submit" class="btn btn-primary font-weight-bold">Update</button>
                                                </div>
                                            </div>
                                        </form>

                                        <form id="delete-form-@item.Id" asp-action="DeleteOrder" method="post" class="m-0">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="button" class="btn btn-danger btn-sm px-2 shadow-sm" title="Delete Permanently" style="border-radius: 4px;" onclick="confirmDelete(@item.Id)">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@foreach (var item in Model)
{
    <div class="modal fade" id="orderModal-@item.Id" tabindex="-1" role="dialog" aria-labelledby="modalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-light">
                    <h5 class="modal-title font-weight-bold text-gray-800" id="modalLabel">Order Details #@item.Id</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body text-left">

                    <h6 class="font-weight-bold text-primary mb-2"><i class="fas fa-map-marker-alt mr-1"></i> Shipping Address</h6>
                    <p class="text-muted small mb-4 pl-3">
                        <strong>City:</strong> @(item.Address?.City ?? "N/A") |
                        <strong>Street:</strong> @(item.Address?.Street ?? "N/A") |
                        <strong>Postal Code:</strong> @(item.Address?.PostalCode ?? "N/A")
                    </p>

                    <h6 class="font-weight-bold text-primary mb-2"><i class="fas fa-shopping-cart mr-1"></i> Cart Items</h6>
                    <div class="table-responsive mb-4">
                        <table class="table table-sm table-bordered bg-white text-center">
                            <thead class="bg-light">
                                <tr>
                                    <th>Product Name</th>
                                    <th>Size/Variant</th>
                                    <th>Quantity</th>
                                    <th>Unit Price</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (item.OrderItems != null && item.OrderItems.Any())
                                {
                                    foreach (var orderItem in item.OrderItems)
                                    {
                                        <tr>
                                            <td>@(orderItem.ProductVariant?.Product?.Name ?? "Shoes")</td>
                                            <td><span class="badge badge-light border">Size: @(orderItem.ProductVariant?.Size ?? "Default")</span></td>
                                            <td>@orderItem.Quantity</td>
                                            <td>$@orderItem.Price</td>
                                            <td class="font-weight-bold text-success">$@(orderItem.Price* orderItem.Quantity)</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-muted">No items found in this order.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <h6 class="font-weight-bold text-primary mb-2"><i class="fas fa-receipt mr-1"></i> Summary</h6>
                    <p class="text-muted small mb-0 pl-3">
                        <strong>Order Date:</strong> @item.OrderDate.ToString("yyyy-MM-dd HH:mm") <br />
                        <strong class="text-primary" style="font-size: 1.1rem;">Total Paid: $@item.TotalPrice</strong>
                    </p>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary btn-sm font-weight-bold" data-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .table td {
        vertical-align: middle !important;
        font-size: 0.9rem;
    }

    .table th {
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
    }

    .custom-select {
        border-radius: 4px 0 0 4px !important;
    }

    .input-group .btn {
        border-radius: 0 4px 4px 0 !important;
    }

    .modal-content {
        border-radius: 8px !important;
    }
</style>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    function confirmDelete(orderId) {
        Swal.fire({
            title: 'Are you sure?',
            text: "This order will be permanently deleted from the database!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'Cancel'
        }).then((result) => {
            if (result.isConfirmed) {
                // تفعيل التوست السريع لإعلام المستخدم بالنجاح قبل تحديث الصفحة
                Swal.fire({
                    toast: true,
                    position: 'top-end',
                    icon: 'success',
                    title: 'Order deleted successfully',
                    showConfirmButton: false,
                    timer: 1500,
                    timerProgressBar: true
                });

                // إرسال الـ Form الحقيقي بعد انتهاء الـ Toast
                setTimeout(() => {
                    document.getElementById('delete-form-' + orderId).submit();
                }, 1500);
            }
        });
    }
</script>