@model IEnumerable<SportsShoesEcommerce.Models.Category>

@{
    ViewData["Title"] = "Categories Management";
    Layout = "_AdminLayout";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800 font-weight-bold">Categories Management</h1>
</div>

<form method="get" asp-action="Index" class="bg-white p-3 rounded shadow-sm mb-4 border-left-info">
    <div class="row align-items-end">
        <div class="form-group col-md-8 mb-2 mb-md-0">
            <label class="small font-weight-bold text-muted">Select Category</label>
            <select name="selectedCategoryId" asp-items="ViewBag.AllCategoriesDropdown" class="form-control form-control-sm">
                <option value="">All Categories </option>
            </select>
        </div>
        <div class="form-group col-md-4 mb-0 text-right">
            <button type="submit" class="btn btn-info btn-sm px-4 font-weight-bold shadow-sm"><i class="fas fa-filter mr-1"></i> Filter</button>
            <a asp-action="Index" class="btn btn-secondary btn-sm px-4 font-weight-bold shadow-sm"><i class="fas fa-undo mr-1"></i> Reset</a>
        </div>
    </div>
</form>

<div class="card shadow mb-4 border-left-info">
    <div class="card-header py-3 d-flex justify-content-between align-items-center bg-light">
        <h6 class="m-0 font-weight-bold text-info"><i class="fas fa-tags mr-2"></i>All Categories</h6>
        <a asp-area="Admin" asp-controller="Categories" asp-action="Create" class="btn btn-info btn-icon-split shadow-sm">
            <span class="icon text-white-50"><i class="fas fa-plus"></i></span>
            <span class="text">Add New Category</span>
        </a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover table-bordered" id="dataTable" width="100%" cellspacing="0">
                <thead class="thead-light text-center">
                    <tr>
                        <th>Image</th>
                        <th>Category Name</th>
                        <th>Description</th>
                        <th style="width: 150px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center align-middle">
                                @if (!string.IsNullOrEmpty(item.ImagePath))
                                {
                                    <img src="~/images/categories/@item.ImagePath" width="50" height="50" class="rounded shadow-sm border" style="object-fit:cover" />
                                }
                                else
                                {
                                    <div class="rounded bg-gray-200 d-flex align-items-center justify-content-center mx-auto shadow-sm" style="width: 50px; height: 50px;">
                                        <i class="fas fa-tags text-gray-400 small"></i>
                                    </div>
                                }
                            </td>
                            <td class="align-middle font-weight-bold text-dark">@item.Name</td>
                            <td class="align-middle">@item.Description</td>
                            <td class="text-center align-middle">
                                <div class="btn-group" role="group">
                                    <a asp-area="Admin" asp-controller="Categories" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-info btn-circle btn-sm shadow-sm"><i class="fas fa-edit"></i></a>
                                    <a asp-area="Admin" asp-controller="Categories" asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary btn-circle btn-sm shadow-sm"><i class="fas fa-info-circle"></i></a>
                                    <a asp-area="Admin" asp-controller="Categories" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-circle btn-sm shadow-sm"><i class="fas fa-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#dataTable').DataTable();
        });
    </script>
}