@model IEnumerable<SportsShoesEcommerce.Models.Review>

@{
    ViewData["Title"] = "Reviews Management";
    Layout = "_AdminLayout";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800 font-weight-bold">Product Reviews</h1>
    </div>

    <form method="get" asp-action="Index" class="bg-white p-3 rounded shadow-sm mb-4 border-left-warning">
        <div class="row align-items-end">

            <div class="form-group col-md-3 mb-2 mb-md-0">
                <label class="small font-weight-bold text-muted">Select Product </label>
                <select name="productId" asp-items="ViewBag.ProductsDropdown" class="form-control form-control-sm">
                    <option value="">All Products </option>
                </select>
            </div>

            <div class="form-group col-md-3 mb-2 mb-md-0">
                <label class="small font-weight-bold text-muted">Rating </label>
                <select name="ratingFilter" class="form-control form-control-sm">
                    <option value="">All Ratings</option>
                    <option value="5" selected="@(ViewData["CurrentRating"]?.ToString() == "5")">⭐⭐⭐⭐⭐ (5 Stars)</option>
                    <option value="4" selected="@(ViewData["CurrentRating"]?.ToString() == "4")">⭐⭐⭐⭐ (4 Stars)</option>
                    <option value="3" selected="@(ViewData["CurrentRating"]?.ToString() == "3")">⭐⭐⭐ (3 Stars)</option>
                    <option value="2" selected="@(ViewData["CurrentRating"]?.ToString() == "2")">⭐⭐ (2 Stars)</option>
                    <option value="1" selected="@(ViewData["CurrentRating"]?.ToString() == "1")">⭐ (1 Star)</option>
                </select>
            </div>

            <div class="form-group col-md-3 mb-2 mb-md-0">
                <label class="small font-weight-bold text-muted">Approval Status</label>
                <select name="isApproved" class="form-control form-control-sm">
                    <option value="">All</option>
                    <option value="true" selected="@(ViewData["CurrentApprovalStatus"]?.ToString() == "True")">Approved </option>
                    <option value="false" selected="@(ViewData["CurrentApprovalStatus"]?.ToString() == "False")">Pending </option>
                </select>
            </div>

            <div class="form-group col-md-3 mb-0 text-right">
                <button type="submit" class="btn btn-warning btn-sm px-3 font-weight-bold text-white shadow-sm"><i class="fas fa-filter mr-1"></i> Filter</button>
                <a asp-action="Index" class="btn btn-secondary btn-sm px-3 font-weight-bold shadow-sm"><i class="fas fa-undo mr-1"></i> Reset</a>
            </div>
        </div>
    </form>

    <div class="card shadow mb-4">
        <div class="card-header py-3 bg-light d-flex align-items-center">
            <i class="fas fa-comments text-primary mr-2"></i>
            <h6 class="m-0 font-weight-bold text-primary">Content Moderation Queue</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover border-0" id="dataTable" width="100%" cellspacing="0">
                    <thead class="bg-gray-100 text-dark">
                        <tr>
                            <th class="border-0">User Info</th>
                            <th class="border-0">Product Name</th>
                            <th class="border-0 text-center">Rating</th>
                            <th class="border-0">User Comment</th>
                            <th class="border-0 text-center">Status</th>
                            <th class="border-0 text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="align-middle">
                                        <div class="font-weight-bold text-dark">@item.User?.UserName</div>
                                        <small class="text-muted">@item.User?.Email</small>
                                    </td>
                                    <td class="align-middle font-weight-bold">@item.Product?.Name</td>
                                    <td class="align-middle text-center">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <i class="fas fa-star @(i <= item.Rating ? "text-warning" : "text-gray-300") small"></i>
                                        }
                                    </td>
                                    <td class="align-middle" style="max-width: 250px;">
                                        <p class="mb-0 text-truncate" title="@item.Comment">@item.Comment</p>
                                    </td>
                                    <td class="align-middle text-center">
                                        @if (item.IsApproved)
                                        {
                                            <span class="badge badge-pill badge-success shadow-sm px-3">Approved</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-pill badge-warning shadow-sm px-3 text-dark">Pending</span>
                                        }
                                    </td>
                                    <td class="align-middle text-center">
                                        <div class="btn-group shadow-sm">
                                            @if (!item.IsApproved)
                                            {
                                                <form asp-action="Approve" asp-route-id="@item.Id" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-success px-3">Approve</button>
                                                </form>
                                            }
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light border">Details</a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <div class="my-3">
                                        <i class="fas fa-inbox fa-3x text-gray-300 mb-3"></i>
                                        <h5 class="text-gray-500">No reviews found for moderation.</h5>
                                        <p class="small text-gray-400">Reviews submitted by users will appear here for approval.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>