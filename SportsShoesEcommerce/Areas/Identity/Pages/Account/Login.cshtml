@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
}

<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,800;1,9..144,600;1,9..144,800&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>
    :root {
        --ns-cream: #faf6ef;
        --ns-sand: #f3ead9;
        --ns-peach: #f5d5b8;
        --ns-terracotta: #c97b5e;
        --ns-clay: #b86048;
        --ns-coffee: #4a3729;
        --ns-mocha: #6b4f3d;
        --ns-sage: #8fa68a;
        --ns-warm-gray: #a89684;
        --ns-soft-shadow: rgba(74, 55, 41, 0.08);
    }

    .ns-auth {
        background: var(--ns-cream);
        color: var(--ns-coffee);
        font-family: 'Inter', -apple-system, sans-serif;
        min-height: 100vh;
        padding: 100px 0 60px;
        position: relative;
        overflow-x: hidden;
    }

        .ns-auth .display-font {
            font-family: 'Fraunces', Georgia, serif;
            font-weight: 800;
            letter-spacing: -0.03em;
            line-height: 0.95;
        }

        .ns-auth .mono {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            font-weight: 500;
        }

    .ns-auth-wrapper {
        max-width: 1180px;
        margin: 0 auto;
        padding: 0 24px;
    }

    .ns-auth-card {
        display: grid;
        grid-template-columns: 1fr 1fr;
        background: var(--ns-cream);
        border-radius: 32px;
        overflow: hidden;
        box-shadow: 0 30px 80px rgba(74, 55, 41, 0.15);
        border: 1px solid rgba(74, 55, 41, 0.08);
        min-height: 640px;
    }

    /* ===== LEFT: BRAND PANEL ===== */
    .ns-auth-brand {
        position: relative;
        background: linear-gradient(160deg, var(--ns-sand) 0%, var(--ns-peach) 100%);
        padding: 50px 48px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        overflow: hidden;
        color: var(--ns-coffee);
    }

        .ns-auth-brand::before {
            content: '';
            position: absolute;
            top: -120px;
            right: -80px;
            width: 380px;
            height: 380px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(201, 123, 94, 0.3) 0%, transparent 70%);
            filter: blur(40px);
        }

        .ns-auth-brand::after {
            content: '';
            position: absolute;
            bottom: -100px;
            left: -100px;
            width: 320px;
            height: 320px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(143, 166, 138, 0.22) 0%, transparent 70%);
            filter: blur(40px);
        }

    .ns-auth-brand-top {
        position: relative;
        z-index: 2;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        color: var(--ns-clay);
    }

    .ns-auth-brand-logo {
        font-family: 'Fraunces', serif;
        font-weight: 800;
        font-size: 1.4rem;
        color: var(--ns-coffee);
        letter-spacing: -0.02em;
    }

    .ns-auth-brand-mid {
        position: relative;
        z-index: 2;
    }

    .ns-auth-brand-tag {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 22px;
        color: var(--ns-clay);
    }

        .ns-auth-brand-tag::before {
            content: '';
            width: 28px;
            height: 2px;
            background: currentColor;
        }

    .ns-auth-brand-title {
        font-size: clamp(2.4rem, 4.5vw, 3.6rem);
        color: var(--ns-coffee);
        margin: 0 0 22px;
    }

        .ns-auth-brand-title em {
            color: var(--ns-clay);
            font-style: italic;
        }

    .ns-auth-brand-text {
        font-size: 1rem;
        line-height: 1.65;
        color: var(--ns-mocha);
        max-width: 380px;
    }

    .ns-auth-brand-bottom {
        position: relative;
        z-index: 2;
        display: flex;
        gap: 40px;
        padding-top: 28px;
        border-top: 1px solid rgba(74, 55, 41, 0.15);
    }

    .ns-auth-stat-num {
        font-family: 'Fraunces', serif;
        font-style: italic;
        font-weight: 800;
        font-size: 1.8rem;
        color: var(--ns-clay);
        line-height: 1;
    }

    .ns-auth-stat-label {
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--ns-mocha);
        margin-top: 6px;
        font-weight: 500;
    }

    /* ===== RIGHT: FORM PANEL ===== */
    .ns-auth-form {
        padding: 60px 56px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        background: var(--ns-cream);
    }

    .ns-auth-form-head {
        margin-bottom: 36px;
    }

    .ns-auth-form-tag {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 14px;
        color: var(--ns-clay);
    }

        .ns-auth-form-tag::before {
            content: '';
            width: 24px;
            height: 2px;
            background: currentColor;
        }

    .ns-auth-form-title {
        font-size: 2.4rem;
        color: var(--ns-coffee);
        margin: 0 0 10px;
    }

        .ns-auth-form-title em {
            color: var(--ns-clay);
            font-style: italic;
        }

    .ns-auth-form-sub {
        font-size: 0.95rem;
        color: var(--ns-mocha);
        margin: 0;
    }

    /* Form fields */
    .ns-field {
        margin-bottom: 18px;
    }

    .ns-field-label {
        display: block;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--ns-mocha);
        font-weight: 600;
        margin-bottom: 8px;
    }

    .ns-field-wrap {
        position: relative;
    }

    .ns-field-icon {
        position: absolute;
        left: 20px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--ns-warm-gray);
        font-size: 0.95rem;
        pointer-events: none;
        transition: color 0.3s ease;
    }

    .ns-auth-form .form-control {
        background: var(--ns-sand);
        border: 1.5px solid transparent;
        border-radius: 14px;
        padding: 16px 20px 16px 50px;
        font-size: 0.95rem;
        color: var(--ns-coffee);
        font-family: 'Inter', sans-serif;
        font-weight: 500;
        transition: all 0.3s ease;
        width: 100%;
        height: auto;
    }

        .ns-auth-form .form-control::placeholder {
            color: var(--ns-warm-gray);
            font-weight: 400;
        }

        .ns-auth-form .form-control:focus {
            background: var(--ns-cream);
            border-color: var(--ns-terracotta);
            box-shadow: 0 0 0 4px rgba(201, 123, 94, 0.12);
            outline: none;
        }

    .ns-field-wrap:focus-within .ns-field-icon {
        color: var(--ns-clay);
    }

    .ns-auth-form .text-danger {
        font-size: 0.78rem;
        color: var(--ns-clay) !important;
        margin-top: 6px;
        display: block;
        font-weight: 500;
    }

    /* Row: remember + forgot */
    .ns-auth-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin: 4px 0 28px;
        flex-wrap: wrap;
        gap: 10px;
    }

    .ns-check {
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
        user-select: none;
    }

        .ns-check input {
            appearance: none;
            -webkit-appearance: none;
            width: 18px;
            height: 18px;
            border: 1.5px solid var(--ns-warm-gray);
            border-radius: 5px;
            background: var(--ns-cream);
            cursor: pointer;
            position: relative;
            transition: all 0.2s ease;
        }

            .ns-check input:checked {
                background: var(--ns-clay);
                border-color: var(--ns-clay);
            }

                .ns-check input:checked::after {
                    content: '✓';
                    position: absolute;
                    top: 50%;
                    left: 50%;
                    transform: translate(-50%, -50%);
                    color: var(--ns-cream);
                    font-size: 0.75rem;
                    font-weight: 700;
                }

        .ns-check label {
            font-size: 0.85rem;
            color: var(--ns-mocha);
            margin: 0;
            cursor: pointer;
        }

    .ns-forgot {
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--ns-clay);
        text-decoration: none;
        position: relative;
        transition: color 0.3s ease;
    }

        .ns-forgot::after {
            content: '';
            position: absolute;
            left: 0;
            bottom: -2px;
            width: 100%;
            height: 1.5px;
            background: var(--ns-clay);
            transform: scaleX(0.6);
            transform-origin: left;
            transition: transform 0.3s ease;
        }

        .ns-forgot:hover {
            color: var(--ns-coffee);
        }

            .ns-forgot:hover::after {
                transform: scaleX(1);
                background: var(--ns-coffee);
            }

    /* Submit button */
    .ns-auth-submit {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        background: var(--ns-coffee);
        color: var(--ns-cream);
        padding: 18px 36px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.9rem;
        letter-spacing: 0.02em;
        font-family: 'Inter', sans-serif;
        border: none;
        cursor: pointer;
        width: 100%;
        transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    }

        .ns-auth-submit:hover {
            background: var(--ns-clay);
            transform: translateY(-3px);
            box-shadow: 0 14px 30px rgba(184, 96, 72, 0.3);
        }

        .ns-auth-submit .arrow {
            transition: transform 0.3s ease;
        }

        .ns-auth-submit:hover .arrow {
            transform: translateX(6px);
        }

    /* Footer link */
    .ns-auth-footer {
        margin-top: 28px;
        padding-top: 24px;
        border-top: 1px solid rgba(74, 55, 41, 0.1);
        text-align: center;
    }

        .ns-auth-footer p {
            font-size: 0.88rem;
            color: var(--ns-mocha);
            margin: 0;
        }

        .ns-auth-footer a {
            color: var(--ns-clay);
            font-weight: 700;
            text-decoration: none;
            position: relative;
        }

            .ns-auth-footer a::after {
                content: '';
                position: absolute;
                left: 0;
                bottom: -2px;
                width: 100%;
                height: 1.5px;
                background: var(--ns-clay);
                transition: background 0.3s ease;
            }

            .ns-auth-footer a:hover {
                color: var(--ns-coffee);
            }

                .ns-auth-footer a:hover::after {
                    background: var(--ns-coffee);
                }

    /* Validation summary */
    .ns-auth-form [asp-validation-summary] ul,
    .ns-auth-form .validation-summary-errors ul {
        background: rgba(184, 96, 72, 0.08);
        border-left: 3px solid var(--ns-clay);
        border-radius: 10px;
        padding: 14px 18px 14px 36px;
        margin-bottom: 20px;
        list-style: none;
    }

    .ns-auth-form .validation-summary-errors li {
        color: var(--ns-clay);
        font-size: 0.85rem;
        font-weight: 500;
    }

    /* Responsive */
    @@media (max-width: 900px) {
        .ns-auth {
            padding: 80px 0 40px;
        }

        .ns-auth-card {
            grid-template-columns: 1fr;
            min-height: auto;
        }

        .ns-auth-brand {
            padding: 40px 36px;
            min-height: 320px;
        }

        .ns-auth-form {
            padding: 44px 36px;
        }
    }

    @@media (max-width: 480px) {
        .ns-auth {
            padding: 70px 0 30px;
        }

        .ns-auth-wrapper {
            padding: 0 16px;
        }

        .ns-auth-brand {
            padding: 32px 26px;
        }

        .ns-auth-form {
            padding: 36px 26px;
        }

        .ns-auth-brand-bottom {
            gap: 24px;
            flex-wrap: wrap;
        }

        .ns-auth-form-title {
            font-size: 2rem;
        }
    }
</style>

<div class="ns-auth">
    <div class="ns-auth-wrapper">
        <div class="ns-auth-card">

            @* ===== LEFT: BRAND PANEL ===== *@
            <div class="ns-auth-brand">
                <div class="ns-auth-brand-top">
                    <span class="ns-auth-brand-logo">NextStep<span style="color: var(--ns-clay);">.</span></span>
                    <span class="mono">001 / SIGN IN</span>
                </div>

                <div class="ns-auth-brand-mid">
                    <div class="ns-auth-brand-tag mono">Welcome Back</div>
                    <h1 class="ns-auth-brand-title display-font">
                        Step back<br />into your <em>journey.</em>
                    </h1>
                    <p class="ns-auth-brand-text">
                        Pick up where you left off. Your cart, your wishlist, your saved looks — all waiting.
                    </p>
                </div>

                <div class="ns-auth-brand-bottom">
                    <div>
                        <div class="ns-auth-stat-num">50+</div>
                        <div class="ns-auth-stat-label">Premium Brands</div>
                    </div>
                    <div>
                        <div class="ns-auth-stat-num">24H</div>
                        <div class="ns-auth-stat-label">Fast Delivery</div>
                    </div>
                    <div>
                        <div class="ns-auth-stat-num">★ 4.9</div>
                        <div class="ns-auth-stat-label">Athlete Rating</div>
                    </div>
                </div>
            </div>

            @* ===== RIGHT: FORM PANEL ===== *@
            <div class="ns-auth-form">
                <div class="ns-auth-form-head">
                    <div class="ns-auth-form-tag mono">Account Access</div>
                    <h2 class="ns-auth-form-title display-font">Sign <em>in.</em></h2>
                    <p class="ns-auth-form-sub">Enter your credentials to continue.</p>
                </div>

                <form id="account" method="post" asp-route-returnUrl="@Model.ReturnUrl">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="ns-field">
                        <label asp-for="Input.Email" class="ns-field-label">Email Address</label>
                        <div class="ns-field-wrap">
                            <i class="fa fa-envelope ns-field-icon"></i>
                            <input asp-for="Input.Email" class="form-control"
                                   autocomplete="username" aria-required="true"
                                   placeholder="you@example.com" />
                        </div>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="ns-field">
                        <label asp-for="Input.Password" class="ns-field-label">Password</label>
                        <div class="ns-field-wrap">
                            <i class="fa fa-lock ns-field-icon"></i>
                            <input asp-for="Input.Password" class="form-control"
                                   autocomplete="current-password" aria-required="true"
                                   placeholder="Enter your password" type="password" />
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="ns-auth-row">
                        <div class="ns-check">
                            <input asp-for="Input.RememberMe" id="rememberMe" type="checkbox" />
                            <label for="rememberMe">Remember me</label>
                        </div>
                        <a id="forgot-password" asp-page="./ForgotPassword" class="ns-forgot">
                            Forgot password?
                        </a>
                    </div>

                    <button id="login-submit" type="submit" class="ns-auth-submit">
                        Sign In
                        <span class="arrow">→</span>
                    </button>
                </form>

                <div class="ns-auth-footer">
                    <p>
                        New to NextStep?
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">
                            Create an account
                        </a>
                    </p>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}