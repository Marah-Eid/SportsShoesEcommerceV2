@inject SignInManager<ApplicationUser> SignInManager
@{
    var hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
}

<style>
    .ns-side-nav {
        background: var(--ns-cream, #faf6ef);
        border: 1px solid rgba(74, 55, 41, 0.08);
        border-radius: 22px;
        padding: 18px;
        box-shadow: 0 4px 20px rgba(74, 55, 41, 0.08);
        font-family: 'Inter', -apple-system, sans-serif;
        position: sticky;
        top: 100px;
    }

    .ns-side-nav-tag {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 6px 14px 14px;
        color: var(--ns-clay, #b86048);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.62rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        font-weight: 600;
        border-bottom: 1px solid rgba(74, 55, 41, 0.08);
        margin-bottom: 10px;
    }

        .ns-side-nav-tag::before {
            content: '';
            width: 20px;
            height: 2px;
            background: currentColor;
        }

    .ns-side-nav-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

        .ns-side-nav-list .nav-link {
            display: flex !important;
            align-items: center;
            gap: 12px;
            padding: 12px 16px !important;
            border-radius: 12px !important;
            font-size: 0.9rem !important;
            font-weight: 500 !important;
            color: var(--ns-mocha, #6b4f3d) !important;
            background: transparent !important;
            text-decoration: none;
            transition: all 0.25s ease;
            position: relative;
        }

            .ns-side-nav-list .nav-link::before {
                content: '';
                position: absolute;
                left: 0;
                top: 50%;
                transform: translateY(-50%);
                width: 3px;
                height: 0;
                background: var(--ns-clay, #b86048);
                border-radius: 0 4px 4px 0;
                transition: height 0.3s ease;
            }

            .ns-side-nav-list .nav-link:hover {
                background: var(--ns-sand, #f3ead9) !important;
                color: var(--ns-coffee, #4a3729) !important;
                padding-left: 22px !important;
            }

            .ns-side-nav-list .nav-link.active {
                background: var(--ns-sand, #f3ead9) !important;
                color: var(--ns-coffee, #4a3729) !important;
                font-weight: 600 !important;
            }

                .ns-side-nav-list .nav-link.active::before {
                    height: 24px;
                }

            .ns-side-nav-list .nav-link i {
                width: 18px;
                font-size: 0.85rem;
                color: var(--ns-warm-gray, #a89684);
                flex-shrink: 0;
                transition: color 0.25s ease;
            }

            .ns-side-nav-list .nav-link:hover i,
            .ns-side-nav-list .nav-link.active i {
                color: var(--ns-clay, #b86048);
            }

            .ns-side-nav-list .nav-link .arrow {
                margin-left: auto;
                opacity: 0;
                color: var(--ns-clay, #b86048);
                font-size: 0.7rem;
                transition: all 0.3s ease;
            }

            .ns-side-nav-list .nav-link:hover .arrow,
            .ns-side-nav-list .nav-link.active .arrow {
                opacity: 1;
            }

    /* Mobile: turn into horizontal scroll pills */
    @@media (max-width: 992px) {
        .ns-side-nav {
            position: static;
            padding: 14px;
            border-radius: 18px;
        }

        .ns-side-nav-tag {
            display: none;
        }

        .ns-side-nav-list {
            flex-direction: row;
            gap: 6px;
            overflow-x: auto;
            padding-bottom: 4px;
        }

            .ns-side-nav-list::-webkit-scrollbar {
                height: 3px;
            }

            .ns-side-nav-list::-webkit-scrollbar-track {
                background: transparent;
            }

            .ns-side-nav-list::-webkit-scrollbar-thumb {
                background: rgba(74, 55, 41, 0.15);
                border-radius: 10px;
            }

            .ns-side-nav-list .nav-item {
                flex-shrink: 0;
            }

            .ns-side-nav-list .nav-link {
                white-space: nowrap;
                padding: 10px 18px !important;
                border-radius: 50px !important;
            }

                .ns-side-nav-list .nav-link::before {
                    display: none;
                }

                .ns-side-nav-list .nav-link:hover {
                    padding-left: 18px !important;
                }

                .ns-side-nav-list .nav-link .arrow {
                    display: none;
                }
    }
</style>

<div class="ns-side-nav">
    <div class="ns-side-nav-tag">Account Settings</div>

    <ul class="nav nav-pills ns-side-nav-list">
        <li class="nav-item">
            <a class="nav-link @ManageNavPages.IndexNavClass(ViewContext)" id="profile" asp-page="./Index">
                <i class="fa fa-user"></i>
                <span>Profile</span>
                <i class="fa fa-chevron-right arrow"></i>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @ManageNavPages.EmailNavClass(ViewContext)" id="email" asp-page="./Email">
                <i class="fa fa-envelope"></i>
                <span>Email</span>
                <i class="fa fa-chevron-right arrow"></i>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @ManageNavPages.ChangePasswordNavClass(ViewContext)" id="change-password" asp-page="./ChangePassword">
                <i class="fa fa-lock"></i>
                <span>Password</span>
                <i class="fa fa-chevron-right arrow"></i>
            </a>
        </li>
        @if (hasExternalLogins)
        {
            <li id="external-logins" class="nav-item">
                <a id="external-login" class="nav-link @ManageNavPages.ExternalLoginsNavClass(ViewContext)" asp-page="./ExternalLogins">
                    <i class="fa fa-link"></i>
                    <span>External Logins</span>
                    <i class="fa fa-chevron-right arrow"></i>
                </a>
            </li>
        }
        <li class="nav-item">
            <a class="nav-link @ManageNavPages.TwoFactorAuthenticationNavClass(ViewContext)" id="two-factor" asp-page="./TwoFactorAuthentication">
                <i class="fa fa-shield-halved"></i>
                <span>Two-Factor Auth</span>
                <i class="fa fa-chevron-right arrow"></i>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @ManageNavPages.PersonalDataNavClass(ViewContext)" id="personal-data" asp-page="./PersonalData">
                <i class="fa fa-database"></i>
                <span>Personal Data</span>
                <i class="fa fa-chevron-right arrow"></i>
            </a>
        </li>
    </ul>
</div>