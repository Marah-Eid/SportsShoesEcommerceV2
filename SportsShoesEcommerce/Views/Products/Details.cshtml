@model SportsShoesEcommerce.Models.ViewModels.ProductDetailsViewModel
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager

@{
    ViewData["Title"] = Model.Product.Name;

    var mainImage = Model.Product.ProductImages?.FirstOrDefault(x => x.IsMain)?.ImagePath
                    ?? Model.Product.ProductImages?.FirstOrDefault()?.ImagePath
                    ?? "/images/single-product-item1.jpg";

    var activeDiscount = Model.Product.Discounts?.FirstOrDefault(d => d.IsActive && d.StartDate <= DateTime.Now && d.EndDate >= DateTime.Now);
    decimal salePrice = Model.Product.Price;
    if (activeDiscount != null)
    {
        salePrice = Model.Product.Price - (Model.Product.Price * activeDiscount.DiscountPercentage / 100m);
    }
}

<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,800;1,9..144,600;1,9..144,800&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>
    :root {
        --ns-cream: #faf6ef;
        --ns-sand: #f3ead9;
        --ns-peach: #f5d5b8;
        --ns-terracotta: #c97b5e;
        --ns-clay: #b86048;
        --ns-coffee: #4a3729;
        --ns-mocha: #6b4f3d;
        --ns-sage: #8fa68a;
        --ns-warm-gray: #a89684;
        --ns-soft-shadow: rgba(74, 55, 41, 0.08);
    }

    .ns-detail {
        background: var(--ns-cream);
        color: var(--ns-coffee);
        font-family: 'Inter', -apple-system, sans-serif;
        padding: 60px 0 80px;
    }

        .ns-detail .display-font {
            font-family: 'Fraunces', Georgia, serif;
            font-weight: 800;
            letter-spacing: -0.03em;
            line-height: 0.95;
        }

        .ns-detail .mono {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            font-weight: 500;
        }

    /* Breadcrumb */
    .ns-breadcrumb {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--ns-mocha);
        margin-bottom: 36px;
        padding-bottom: 20px;
        border-bottom: 1px solid rgba(74, 55, 41, 0.08);
    }

        .ns-breadcrumb a {
            color: var(--ns-mocha);
            text-decoration: none;
            transition: color 0.3s ease;
        }

            .ns-breadcrumb a:hover {
                color: var(--ns-clay);
            }

        .ns-breadcrumb .sep {
            color: var(--ns-warm-gray);
            opacity: 0.6;
        }

        .ns-breadcrumb .current {
            color: var(--ns-coffee);
            font-weight: 600;
        }

    /* Layout */
    .ns-detail-grid {
        display: grid;
        grid-template-columns: 1.3fr 1fr;
        gap: 60px;
        align-items: start;
    }

    /* ===== GALLERY ===== */
    .ns-gallery {
        position: relative;
    }

    .ns-gallery-main {
        position: relative;
        background: linear-gradient(160deg, var(--ns-sand) 0%, var(--ns-peach) 100%);
        border-radius: 28px;
        overflow: hidden;
        aspect-ratio: 4 / 5;
        margin-bottom: 18px;
    }

        .ns-gallery-main::before {
            content: '';
            position: absolute;
            top: -80px;
            right: -60px;
            width: 240px;
            height: 240px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(201, 123, 94, 0.2) 0%, transparent 70%);
            filter: blur(30px);
            pointer-events: none;
        }

    .ns-gallery-img-wrap {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px;
        z-index: 2;
    }

        .ns-gallery-img-wrap img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
            transition: opacity 0.25s ease, transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
        }

    .ns-gallery-main:hover .ns-gallery-img-wrap img {
        transform: scale(1.06);
    }

    .ns-gallery-discount {
        position: absolute;
        top: 22px;
        left: 22px;
        background: var(--ns-clay);
        color: var(--ns-cream);
        padding: 10px 18px;
        border-radius: 50px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        font-weight: 700;
        z-index: 3;
        box-shadow: 0 10px 24px rgba(184, 96, 72, 0.3);
    }

    .ns-gallery-marker {
        position: absolute;
        top: 22px;
        right: 22px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.65rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--ns-clay);
        z-index: 3;
        background: rgba(250, 246, 239, 0.92);
        backdrop-filter: blur(8px);
        padding: 8px 14px;
        border-radius: 50px;
        font-weight: 600;
    }

    .ns-thumbs {
        display: flex;
        gap: 12px;
        overflow-x: auto;
        padding-bottom: 6px;
    }

        .ns-thumbs::-webkit-scrollbar {
            height: 4px;
        }

        .ns-thumbs::-webkit-scrollbar-track {
            background: var(--ns-sand);
            border-radius: 10px;
        }

        .ns-thumbs::-webkit-scrollbar-thumb {
            background: var(--ns-warm-gray);
            border-radius: 10px;
        }

    .ns-thumb {
        flex-shrink: 0;
        width: 90px;
        height: 90px;
        background: var(--ns-sand);
        border-radius: 16px;
        padding: 10px;
        cursor: pointer;
        border: 2px solid transparent;
        opacity: 0.55;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .ns-thumb:hover,
        .ns-thumb.active {
            opacity: 1;
            border-color: var(--ns-terracotta);
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(184, 96, 72, 0.12);
        }

        .ns-thumb img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

    /* ===== INFO PANEL ===== */
    .ns-info {
        position: sticky;
        top: 100px;
    }

    .ns-info-brand {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 18px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--ns-clay);
        font-weight: 600;
    }

        .ns-info-brand::before {
            content: '';
            width: 24px;
            height: 2px;
            background: currentColor;
        }

    .ns-info-name {
        font-size: clamp(2rem, 4vw, 3rem);
        color: var(--ns-coffee);
        margin: 0 0 22px;
        line-height: 1.05;
    }

    .ns-info-rating-row {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 24px;
        padding-bottom: 24px;
        border-bottom: 1px solid rgba(74, 55, 41, 0.1);
    }

    .ns-info-stars {
        display: flex;
        gap: 3px;
        color: var(--ns-clay);
        font-size: 0.95rem;
    }

        .ns-info-stars .dim {
            opacity: 0.25;
        }

    .ns-info-rating-num {
        font-family: 'Fraunces', serif;
        font-style: italic;
        font-weight: 700;
        font-size: 1.1rem;
        color: var(--ns-coffee);
    }

    .ns-info-rating-count {
        color: var(--ns-mocha);
        text-decoration: none;
        font-size: 0.85rem;
        margin-left: 6px;
        transition: color 0.3s ease;
    }

        .ns-info-rating-count:hover {
            color: var(--ns-clay);
        }

    /* Price */
    .ns-info-price {
        margin-bottom: 28px;
        display: flex;
        align-items: baseline;
        gap: 14px;
        flex-wrap: wrap;
    }

    .ns-info-price-current {
        font-family: 'Fraunces', serif;
        font-weight: 800;
        font-style: italic;
        font-size: 3rem;
        color: var(--ns-clay);
        line-height: 1;
    }

    .ns-info-price-old {
        font-family: 'Fraunces', serif;
        font-size: 1.5rem;
        color: var(--ns-warm-gray);
        text-decoration: line-through;
        text-decoration-color: var(--ns-clay);
        font-weight: 600;
    }

    .ns-info-desc {
        font-size: 0.98rem;
        color: var(--ns-mocha);
        line-height: 1.7;
        margin-bottom: 32px;
    }

    /* Form / Add to cart panel */
    .ns-add-panel {
        background: var(--ns-sand);
        border: 1px solid rgba(74, 55, 41, 0.06);
        border-radius: 22px;
        padding: 26px;
        margin-bottom: 24px;
    }

    .ns-field-label {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--ns-mocha);
        margin-bottom: 10px;
        font-weight: 600;
    }

        .ns-field-label a {
            color: var(--ns-clay);
            text-decoration: none;
            font-weight: 600;
        }

            .ns-field-label a:hover {
                color: var(--ns-coffee);
            }

    .ns-select {
        width: 100%;
        background: var(--ns-cream);
        border: 1.5px solid transparent;
        border-radius: 14px;
        padding: 16px 22px;
        font-size: 0.95rem;
        font-family: 'Inter', sans-serif;
        font-weight: 500;
        color: var(--ns-coffee);
        cursor: pointer;
        appearance: none;
        background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' fill='%234a3729'><path d='M8 11.5L2 5.5l1.4-1.4L8 8.7l4.6-4.6L14 5.5z'/></svg>");
        background-repeat: no-repeat;
        background-position: right 20px center;
        background-size: 14px;
        padding-right: 50px;
        transition: all 0.3s ease;
    }

        .ns-select:focus {
            outline: none;
            border-color: var(--ns-terracotta);
            box-shadow: 0 0 0 4px rgba(201, 123, 94, 0.12);
        }

    .ns-actions {
        display: flex;
        gap: 10px;
        margin-top: 20px;
    }

    .ns-add-cart {
        flex: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        background: var(--ns-coffee);
        color: var(--ns-cream);
        padding: 17px 28px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.9rem;
        letter-spacing: 0.02em;
        border: none;
        cursor: pointer;
        transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    }

        .ns-add-cart:hover {
            background: var(--ns-clay);
            color: var(--ns-cream);
            transform: translateY(-3px);
            box-shadow: 0 14px 30px rgba(184, 96, 72, 0.3);
        }

        .ns-add-cart .arrow {
            transition: transform 0.3s ease;
        }

        .ns-add-cart:hover .arrow {
            transform: translateX(6px);
        }

    .ns-wishlist-btn {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: var(--ns-cream);
        color: var(--ns-coffee);
        border: 1.5px solid rgba(74, 55, 41, 0.1);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s ease;
        font-size: 1rem;
    }

        .ns-wishlist-btn:hover {
            background: var(--ns-clay);
            color: var(--ns-cream);
            border-color: var(--ns-clay);
            transform: translateY(-3px);
        }

    /* Perks */
    .ns-perks {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

        .ns-perks li {
            display: flex;
            align-items: center;
            gap: 14px;
            font-size: 0.9rem;
            color: var(--ns-mocha);
            font-weight: 500;
        }

    .ns-perks-icon {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: var(--ns-sand);
        color: var(--ns-clay);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
        flex-shrink: 0;
    }

    /* ===== REVIEWS ===== */
    .ns-reviews-section {
        margin-top: 90px;
        padding-top: 60px;
        border-top: 1px solid rgba(74, 55, 41, 0.08);
    }

    .ns-reviews-header {
        margin-bottom: 40px;
    }

    .ns-reviews-tag {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 14px;
        color: var(--ns-clay);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        font-weight: 500;
    }

        .ns-reviews-tag::before {
            content: '';
            width: 28px;
            height: 2px;
            background: currentColor;
        }

    .ns-reviews-title {
        font-family: 'Fraunces', serif;
        font-weight: 800;
        font-size: clamp(2rem, 4vw, 3rem);
        color: var(--ns-coffee);
        letter-spacing: -0.03em;
        margin: 0;
    }

        .ns-reviews-title em {
            color: var(--ns-clay);
            font-style: italic;
        }

    .ns-reviews-grid {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 40px;
        align-items: start;
    }

    .ns-review-form-card {
        background: var(--ns-cream);
        border: 1px solid rgba(74, 55, 41, 0.08);
        border-radius: 24px;
        padding: 32px 28px;
        box-shadow: 0 4px 20px var(--ns-soft-shadow);
        position: sticky;
        top: 100px;
    }

    .ns-review-form-title {
        font-family: 'Fraunces', serif;
        font-weight: 800;
        font-size: 1.5rem;
        color: var(--ns-coffee);
        letter-spacing: -0.02em;
        margin: 0 0 4px;
    }

    .ns-review-form-sub {
        font-size: 0.85rem;
        color: var(--ns-mocha);
        margin: 0 0 24px;
    }

    .ns-stars-input {
        display: flex;
        flex-direction: row-reverse;
        justify-content: center;
        gap: 8px;
        margin-bottom: 22px;
    }

        .ns-stars-input input {
            display: none;
        }

        .ns-stars-input label {
            font-size: 2rem;
            color: rgba(74, 55, 41, 0.15);
            cursor: pointer;
            transition: all 0.2s ease;
            margin: 0;
        }

            .ns-stars-input input:checked ~ label,
            .ns-stars-input label:hover,
            .ns-stars-input label:hover ~ label {
                color: var(--ns-clay);
                transform: scale(1.08);
            }

    .ns-textarea {
        width: 100%;
        background: var(--ns-sand);
        border: 1.5px solid transparent;
        border-radius: 14px;
        padding: 16px 20px;
        font-size: 0.92rem;
        color: var(--ns-coffee);
        font-family: 'Inter', sans-serif;
        font-weight: 500;
        resize: vertical;
        min-height: 110px;
        transition: all 0.3s ease;
        margin-bottom: 16px;
    }

        .ns-textarea:focus {
            outline: none;
            border-color: var(--ns-terracotta);
            background: var(--ns-cream);
            box-shadow: 0 0 0 4px rgba(201, 123, 94, 0.12);
        }

        .ns-textarea::placeholder {
            color: var(--ns-warm-gray);
            font-weight: 400;
        }

    .ns-submit-review {
        width: 100%;
        background: var(--ns-coffee);
        color: var(--ns-cream);
        border: none;
        border-radius: 50px;
        padding: 15px 28px;
        font-weight: 600;
        font-size: 0.85rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.35s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

        .ns-submit-review:hover {
            background: var(--ns-clay);
            transform: translateY(-2px);
            box-shadow: 0 12px 24px rgba(184, 96, 72, 0.25);
        }

    .ns-signin-prompt {
        text-align: center;
        padding: 30px 10px;
    }

    .ns-signin-icon {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: var(--ns-sand);
        color: var(--ns-clay);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        margin-bottom: 16px;
    }

    .ns-signin-prompt h6 {
        font-family: 'Fraunces', serif;
        font-weight: 800;
        font-size: 1.2rem;
        color: var(--ns-coffee);
        margin: 0 0 6px;
    }

    .ns-signin-prompt p {
        font-size: 0.85rem;
        color: var(--ns-mocha);
        margin: 0 0 20px;
    }

    .ns-signin-btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: var(--ns-coffee);
        color: var(--ns-cream);
        padding: 12px 26px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.82rem;
        text-decoration: none;
        transition: all 0.3s ease;
    }

        .ns-signin-btn:hover {
            background: var(--ns-clay);
            color: var(--ns-cream);
            transform: translateY(-2px);
        }

    /* Review tiles */
    .ns-review-list {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .ns-review-tile {
        background: var(--ns-cream);
        border: 1px solid rgba(74, 55, 41, 0.08);
        border-radius: 22px;
        padding: 26px 28px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 16px var(--ns-soft-shadow);
    }

        .ns-review-tile:hover {
            border-color: var(--ns-terracotta);
            transform: translateY(-3px);
            box-shadow: 0 14px 28px rgba(184, 96, 72, 0.1);
        }

    .ns-review-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
        margin-bottom: 16px;
    }

    .ns-review-user {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .ns-review-avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid var(--ns-terracotta);
    }

    .ns-review-name {
        font-family: 'Fraunces', serif;
        font-weight: 700;
        font-size: 1rem;
        color: var(--ns-coffee);
        margin: 0 0 2px;
    }

    .ns-review-date {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--ns-mocha);
    }

    .ns-review-stars {
        color: var(--ns-clay);
        font-size: 0.9rem;
        display: flex;
        gap: 3px;
        flex-shrink: 0;
    }

        .ns-review-stars .dim {
            opacity: 0.25;
        }

    .ns-review-body {
        font-family: 'Fraunces', serif;
        font-style: italic;
        font-size: 1rem;
        line-height: 1.55;
        color: var(--ns-coffee);
        margin: 0;
    }

    .ns-empty-reviews {
        text-align: center;
        padding: 60px 30px;
        background: var(--ns-sand);
        border-radius: 22px;
        border: 1.5px dashed rgba(74, 55, 41, 0.15);
    }

        .ns-empty-reviews i {
            font-size: 2.2rem;
            color: var(--ns-warm-gray);
            margin-bottom: 18px;
        }

        .ns-empty-reviews h5 {
            font-family: 'Fraunces', serif;
            font-weight: 800;
            font-style: italic;
            font-size: 1.4rem;
            color: var(--ns-coffee);
            margin: 0 0 8px;
        }

        .ns-empty-reviews p {
            font-size: 0.92rem;
            color: var(--ns-mocha);
            margin: 0;
        }

    /* Responsive */
    @@media (max-width: 992px) {
        .ns-detail-grid {
            grid-template-columns: 1fr;
            gap: 36px;
        }

        .ns-info {
            position: static;
        }

        .ns-reviews-grid {
            grid-template-columns: 1fr;
            gap: 30px;
        }

        .ns-review-form-card {
            position: static;
        }
    }

    @@media (max-width: 576px) {
        .ns-detail {
            padding: 40px 0 60px;
        }

        .ns-info-price-current {
            font-size: 2.4rem;
        }

        .ns-add-panel {
            padding: 20px;
        }

        .ns-review-tile {
            padding: 22px 20px;
        }
    }
</style>

<div class="ns-detail">
    <div class="container">

        @* ===== BREADCRUMB ===== *@
        <nav class="ns-breadcrumb">
            <a asp-controller="Home" asp-action="Index"><i class="fa fa-home me-1"></i> Home</a>
            <span class="sep">/</span>
            <a asp-controller="Search" asp-action="Index" asp-route-q="@Model.Product.Category?.Name">@(Model.Product.Category?.Name ?? "Shoes")</a>
            <span class="sep">/</span>
            <span class="current">@Model.Product.Name</span>
        </nav>

        <div class="ns-detail-grid">

            @* ===== GALLERY ===== *@
            <div class="ns-gallery">
                <div class="ns-gallery-main">
                    @if (activeDiscount != null)
                    {
                        <span class="ns-gallery-discount">Save @activeDiscount.DiscountPercentage.ToString("0")%</span>
                    }
                    <span class="ns-gallery-marker">@(Model.Product.Brand?.Name ?? "NextStep")</span>

                    <div class="ns-gallery-img-wrap">
                        <img id="mainProductImage" src="@mainImage" alt="@Model.Product.Name">
                    </div>
                </div>

                @if (Model.Product.ProductImages != null && Model.Product.ProductImages.Count > 1)
                {
                    <div class="ns-thumbs">
                        @{
                            int thumbIndex = 0;
                        }
                        @foreach (var img in Model.Product.ProductImages)
                        {
                            <div class="ns-thumb @(thumbIndex == 0 ? "active" : "")" onclick="changeMainImage('@img.ImagePath', this)">
                                <img src="@img.ImagePath" alt="thumbnail">
                            </div>
                            thumbIndex++;
                        }
                    </div>
                }
            </div>

            @* ===== INFO PANEL ===== *@
            <div class="ns-info">
                <div class="ns-info-brand">@(Model.Product.Brand?.Name ?? "NextStep")</div>

                <h1 class="ns-info-name display-font">@Model.Product.Name</h1>

                <div class="ns-info-rating-row">
                    <div class="ns-info-stars">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <i class="fa fa-star @(i <= Math.Round(Model.AverageRating) ? "" : "dim")"></i>
                        }
                    </div>
                    <span class="ns-info-rating-num">@Model.AverageRating.ToString("0.0")</span>
                    <a href="#reviewsSection" class="ns-info-rating-count">(@Model.TotalReviews reviews)</a>
                </div>

                <div class="ns-info-price">
                    @if (activeDiscount != null)
                    {
                        <span class="ns-info-price-current">$@salePrice.ToString("0.00")</span>
                        <span class="ns-info-price-old">$@Model.Product.Price.ToString("0.00")</span>
                    }
                    else
                    {
                        <span class="ns-info-price-current">$@Model.Product.Price.ToString("0.00")</span>
                    }
                </div>

                <p class="ns-info-desc">@Model.Product.Description</p>

                <form asp-controller="Cart" asp-action="AddToCart" method="post" class="ns-add-panel">

                    <div class="ns-field-label">
                        <span>Select Size</span>
                        <a href="#">Size Guide ↗</a>
                    </div>

                    <select name="productVariantId" class="ns-select" required>
                        <option value="" disabled selected>Choose your size...</option>

                        @if (Model.Product.ProductVariants != null && Model.Product.ProductVariants.Any())
                        {
                            foreach (var variant in Model.Product.ProductVariants.Where(v => v.StockQuantity > 0))
                            {
                                <option value="@variant.Id">Size @variant.Size @(!string.IsNullOrEmpty(variant.Color) && variant.Color != "Default" ? $" - {variant.Color}" : "")</option>
                            }

                            if (!Model.Product.ProductVariants.Any(v => v.StockQuantity > 0))
                            {
                                <option value="" disabled>Out of Stock</option>
                            }
                        }
                        else
                        {
                            <option value="" disabled>Currently Unavailable</option>
                        }
                    </select>

                    <div class="ns-actions">
                        <button type="submit" class="ns-add-cart" @(Model.Product.ProductVariants == null || !Model.Product.ProductVariants.Any(v => v.StockQuantity > 0) ? "disabled style='opacity:0.5;'" : "")>
                            Add to Cart
                            <span class="arrow">→</span>
                        </button>

                        <a asp-controller="Wishlist" asp-action="Add" asp-route-productId="@Model.Product.Id" class="ns-wishlist-btn" title="Add to Wishlist" style="text-decoration: none;">
                            <i class="fa fa-heart"></i>
                        </a>
                    </div>
                </form>

                <ul class="ns-perks">
                    <li>
                        <span class="ns-perks-icon"><i class="fa fa-truck"></i></span>
                        <span>Free shipping on orders over $100</span>
                    </li>
                    <li>
                        <span class="ns-perks-icon"><i class="fa fa-undo"></i></span>
                        <span>Free 30-day returns</span>
                    </li>
                    <li>
                        <span class="ns-perks-icon"><i class="fa fa-shield-halved"></i></span>
                        <span>Authenticity guaranteed</span>
                    </li>
                </ul>
            </div>
        </div>

        @* ===== REVIEWS ===== *@
        <section id="reviewsSection" class="ns-reviews-section">

            <div class="ns-reviews-header">
                <div class="ns-reviews-tag">Customer Reviews</div>
                <h2 class="ns-reviews-title">What athletes <em>say.</em></h2>
            </div>

            <div class="ns-reviews-grid">

                <div class="ns-review-form-card">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <h3 class="ns-review-form-title">Write a Review</h3>
                        <p class="ns-review-form-sub">Share your thoughts with other athletes.</p>

                        <form asp-controller="Products" asp-action="AddReview" method="post">
                            <input type="hidden" name="ProductId" value="@Model.Product.Id" />

                            <div class="ns-stars-input">
                                <input type="radio" id="star5" name="NewRating" value="5" required />
                                <label for="star5" class="fa fa-star"></label>
                                <input type="radio" id="star4" name="NewRating" value="4" />
                                <label for="star4" class="fa fa-star"></label>
                                <input type="radio" id="star3" name="NewRating" value="3" />
                                <label for="star3" class="fa fa-star"></label>
                                <input type="radio" id="star2" name="NewRating" value="2" />
                                <label for="star2" class="fa fa-star"></label>
                                <input type="radio" id="star1" name="NewRating" value="1" />
                                <label for="star1" class="fa fa-star"></label>
                            </div>

                            <textarea class="ns-textarea" name="NewReviewComment" rows="4" placeholder="How did the shoe feel?" required></textarea>

                            <button type="submit" class="ns-submit-review">
                                Submit Review
                                <span>→</span>
                            </button>
                        </form>
                    }
                    else
                    {
                        <div class="ns-signin-prompt">
                            <div class="ns-signin-icon">
                                <i class="fa fa-lock"></i>
                            </div>
                            <h6>Members Only</h6>
                            <p>Please sign in to share your experience.</p>
                            <a asp-area="Identity" asp-page="/Account/Login" class="ns-signin-btn">
                                Sign In
                                <span>→</span>
                            </a>
                        </div>
                    }
                </div>

                <div>
                    @if (Model.Reviews.Any())
                    {
                        <div class="ns-review-list">
                            @foreach (var review in Model.Reviews)
                            {
                                <div class="ns-review-tile">
                                    <div class="ns-review-head">
                                        <div class="ns-review-user">
                                            <img src="@(review.User?.ProfileImage ?? "/admin/img/undraw_profile.svg")" class="ns-review-avatar" alt="User">
                                            <div>
                                                <p class="ns-review-name">@(review.User?.FullName ?? "Verified Buyer")</p>
                                                <span class="ns-review-date">@review.CreatedAt.ToString("MMM dd, yyyy")</span>
                                            </div>
                                        </div>
                                        <div class="ns-review-stars">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="fa fa-star @(i <= review.Rating ? "" : "dim")"></i>
                                            }
                                        </div>
                                    </div>
                                    <p class="ns-review-body">"@review.Comment"</p>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="ns-empty-reviews">
                            <i class="fa fa-comment-dots"></i>
                            <h5>No reviews yet.</h5>
                            <p>Be the first to review the @Model.Product.Name.</p>
                        </div>
                    }
                </div>

            </div>
        </section>

    </div>
</div>

@section Scripts {
    <script>
        function changeMainImage(src, element) {
            let mainImage = document.getElementById('mainProductImage');
            mainImage.style.opacity = '0';

            setTimeout(() => {
                mainImage.src = src;
                mainImage.style.opacity = '1';
            }, 180);

            document.querySelectorAll('.ns-thumb').forEach(t => t.classList.remove('active'));
            element.classList.add('active');
        }
    </script>
}