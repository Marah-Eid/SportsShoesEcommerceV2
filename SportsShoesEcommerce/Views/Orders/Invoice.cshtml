@model SportsShoesEcommerce.Models.Order

@{
    ViewData["Title"] = "Invoice";
}

<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,800;1,9..144,600;1,9..144,800&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>
    :root {
        --ns-cream: #faf6ef;
        --ns-sand: #f3ead9;
        --ns-peach: #f5d5b8;
        --ns-terracotta: #c97b5e;
        --ns-clay: #b86048;
        --ns-coffee: #4a3729;
        --ns-mocha: #6b4f3d;
        --ns-sage: #8fa68a;
        --ns-warm-gray: #a89684;
    }

    body {
        background: var(--ns-cream);
    }

    .ns-invoice-page {
        background: var(--ns-cream);
        min-height: 100vh;
        padding: 90px 0 70px;
        font-family: 'Inter', sans-serif;
        color: var(--ns-coffee);
    }

    .ns-invoice-wrapper {
        max-width: 1150px;
        margin: 0 auto;
        padding: 0 24px;
    }

    /* HEADER */

    .ns-invoice-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 30px;
        margin-bottom: 36px;
    }

    .ns-brand-tag {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 18px;
        color: var(--ns-clay);
        font-family: 'JetBrains Mono', monospace;
        font-size: .72rem;
        letter-spacing: .18em;
        text-transform: uppercase;
        font-weight: 500;
    }

        .ns-brand-tag::before {
            content: '';
            width: 26px;
            height: 2px;
            background: currentColor;
        }

    .ns-invoice-title {
        font-family: 'Fraunces', serif;
        font-size: clamp(2.8rem, 5vw, 4.5rem);
        line-height: .92;
        letter-spacing: -0.04em;
        font-weight: 800;
        margin: 0 0 10px;
        color: var(--ns-coffee);
    }

        .ns-invoice-title em {
            color: var(--ns-clay);
            font-style: italic;
        }

    .ns-brand-name {
        color: var(--ns-mocha);
        font-size: 1rem;
        margin: 0;
    }

    .ns-invoice-meta {
        text-align: right;
    }

    .ns-invoice-number {
        font-family: 'Fraunces', serif;
        font-size: 1.8rem;
        color: var(--ns-coffee);
        margin-bottom: 10px;
    }

    .ns-invoice-date {
        color: var(--ns-warm-gray);
        font-weight: 500;
    }

    /* MAIN CARD */

    .ns-invoice-card {
        background: rgba(255,255,255,.76);
        backdrop-filter: blur(10px);
        border-radius: 34px;
        overflow: hidden;
        border: 1px solid rgba(74,55,41,.08);
        box-shadow: 0 30px 80px rgba(74,55,41,.10);
    }

    .ns-section {
        padding: 36px 42px;
        border-bottom: 1px solid rgba(74,55,41,.08);
    }

        .ns-section:last-child {
            border-bottom: none;
        }

    /* CUSTOMER GRID */

    .ns-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 30px;
    }

    .ns-section-title {
        font-family: 'Fraunces', serif;
        font-size: 1.5rem;
        margin-bottom: 18px;
        color: var(--ns-coffee);
    }

    .ns-info-box {
        background: rgba(243,234,217,.5);
        border-radius: 22px;
        padding: 24px;
        border: 1px solid rgba(74,55,41,.05);
    }

    .ns-info-label {
        font-size: .72rem;
        letter-spacing: .15em;
        text-transform: uppercase;
        color: var(--ns-warm-gray);
        font-weight: 700;
        margin-bottom: 10px;
        display: block;
    }

    .ns-info-value {
        color: var(--ns-coffee);
        font-weight: 600;
        line-height: 1.8;
    }

    /* TABLE */

    .ns-table-wrap {
        overflow-x: auto;
    }

    .ns-products-table {
        width: 100%;
        border-collapse: collapse;
    }

        .ns-products-table thead {
            background: var(--ns-coffee);
        }

        .ns-products-table th {
            padding: 22px 24px;
            color: var(--ns-cream);
            font-size: .76rem;
            letter-spacing: .14em;
            text-transform: uppercase;
            font-weight: 600;
        }

        .ns-products-table td {
            padding: 24px;
            border-bottom: 1px solid rgba(74,55,41,.08);
            vertical-align: middle;
            font-weight: 500;
            color: var(--ns-coffee);
        }

        .ns-products-table tbody tr {
            transition: .25s ease;
        }

            .ns-products-table tbody tr:hover {
                background: rgba(243,234,217,.4);
            }

            .ns-products-table tbody tr:last-child td {
                border-bottom: none;
            }

    .ns-product-name {
        font-weight: 700;
    }

    .ns-price {
        font-weight: 700;
    }

    /* TOTAL AREA */

    .ns-total-section {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 30px;
        flex-wrap: wrap;
    }

    .ns-payment-info {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .ns-payment-row {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .ns-payment-label {
        font-size: .75rem;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: var(--ns-warm-gray);
        font-weight: 700;
    }

    .ns-payment-value {
        font-weight: 600;
        color: var(--ns-coffee);
    }

    .ns-total-box {
        background: var(--ns-coffee);
        color: var(--ns-cream);
        border-radius: 24px;
        padding: 26px 34px;
        min-width: 260px;
        text-align: right;
    }

    .ns-total-label {
        font-size: .75rem;
        letter-spacing: .15em;
        text-transform: uppercase;
        opacity: .7;
        margin-bottom: 10px;
    }

    .ns-total-value {
        font-family: 'Fraunces', serif;
        font-size: 2.5rem;
        line-height: 1;
    }

    /* ACTIONS */

    .ns-actions {
        display: flex;
        justify-content: flex-end;
        gap: 14px;
        margin-top: 28px;
        flex-wrap: wrap;
    }

    .ns-btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 16px 24px;
        border-radius: 16px;
        text-decoration: none;
        border: none;
        font-weight: 600;
        font-size: .92rem;
        transition: .25s ease;
        cursor: pointer;
    }

    .ns-btn-dark {
        background: var(--ns-coffee);
        color: var(--ns-cream);
    }

        .ns-btn-dark:hover {
            background: var(--ns-clay);
            color: var(--ns-cream);
            transform: translateY(-2px);
        }

    .ns-btn-light {
        background: transparent;
        border: 1px solid rgba(74,55,41,.12);
        color: var(--ns-coffee);
    }

        .ns-btn-light:hover {
            background: var(--ns-sand);
            color: var(--ns-coffee);
        }

    /* PRINT */

    @@media print {

        body {
            background: white !important;
        }

        .ns-actions {
            display: none !important;
        }

        .ns-invoice-page {
            padding: 0;
        }

        .ns-invoice-card {
            box-shadow: none;
            border: none;
        }
    }

    /* RESPONSIVE */

    @@media (max-width: 900px) {

        .ns-grid {
            grid-template-columns: 1fr;
        }

        .ns-invoice-header {
            flex-direction: column;
        }

        .ns-invoice-meta {
            text-align: left;
        }

        .ns-products-table {
            min-width: 800px;
        }
    }

    @@media (max-width: 600px) {

        .ns-invoice-page {
            padding: 70px 0 50px;
        }

        .ns-invoice-wrapper {
            padding: 0 16px;
        }

        .ns-section {
            padding: 26px 22px;
        }

        .ns-total-box {
            width: 100%;
            text-align: left;
        }

        .ns-actions {
            flex-direction: column;
        }

        .ns-btn {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<div class="ns-invoice-page">

    <div class="ns-invoice-wrapper">

        <!-- HEADER -->
        <div class="ns-invoice-header">

            <div>

                <div class="ns-brand-tag">
                    Official Invoice
                </div>

                <h1 class="ns-invoice-title">
                    Purchase <em>Invoice.</em>
                </h1>

                <p class="ns-brand-name">
                    NextStep — Athletic Footwear
                </p>

            </div>

            <div class="ns-invoice-meta">

                <div class="ns-invoice-number">
                    #@Model.Id
                </div>

                <div class="ns-invoice-date">
                    @Model.OrderDate.ToString("dd MMM yyyy")
                </div>

            </div>

        </div>

        <!-- CARD -->
        <div class="ns-invoice-card" id="invoiceArea">

            <!-- CUSTOMER + ADDRESS -->
            <div class="ns-section">

                <div class="ns-grid">

                    <div>

                        <h3 class="ns-section-title">
                            Customer
                        </h3>

                        <div class="ns-info-box">

                            <span class="ns-info-label">
                                Full Name
                            </span>

                            <div class="ns-info-value">
                                @Model.User?.FullName
                            </div>

                        </div>

                    </div>

                    <div>

                        <h3 class="ns-section-title">
                            Shipping Address
                        </h3>

                        <div class="ns-info-box">

                            <div class="ns-info-value">
                                @Model.Address?.City
                                <br />
                                @Model.Address?.Street
                                <br />
                                @Model.Address?.PostalCode
                            </div>

                        </div>

                    </div>

                </div>

            </div>

            <!-- PRODUCTS -->
            <div class="ns-section">

                <div class="ns-table-wrap">

                    <table class="ns-products-table">

                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Size</th>
                                <th>Color</th>
                                <th>Price</th>
                                <th>Qty</th>
                                <th>Total</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var item in Model.OrderItems)
                            {
                                <tr>

                                    <td class="ns-product-name">
                                        @item.ProductVariant?.Product?.Name
                                    </td>

                                    <td>
                                        @item.ProductVariant?.Size
                                    </td>

                                    <td>
                                        @item.ProductVariant?.Color
                                    </td>

                                    <td class="ns-price">
                                        $@item.Price
                                    </td>

                                    <td>
                                        @item.Quantity
                                    </td>

                                    <td class="ns-price">
                                        $@(item.Price * item.Quantity)
                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

            <!-- TOTAL -->
            <div class="ns-section">

                <div class="ns-total-section">

                    <div class="ns-payment-info">

                        <div class="ns-payment-row">

                            <span class="ns-payment-label">
                                Payment Status
                            </span>

                            <span class="ns-payment-value">
                                @Model.Payment?.PaymentStatus
                            </span>

                        </div>

                        <div class="ns-payment-row">

                            <span class="ns-payment-label">
                                Payment Method
                            </span>

                            <span class="ns-payment-value">
                                @Model.Payment?.PaymentMethod
                            </span>

                        </div>

                    </div>

                    <div class="ns-total-box">

                        <div class="ns-total-label">
                            Grand Total
                        </div>

                        <div class="ns-total-value">
                            $@Model.TotalPrice
                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- ACTIONS -->
        <div class="ns-actions">

            <button onclick="window.print()"
                    class="ns-btn ns-btn-dark">

                <i class="fa fa-print"></i>
                Print Invoice

            </button>

            <a asp-controller="Orders"
               asp-action="Details"
               asp-route-id="@Model.Id"
               class="ns-btn ns-btn-light">

                <i class="fa fa-arrow-left"></i>
                Back to Details

            </a>

        </div>

    </div>

</div>