@model SportsShoesEcommerce.Models.ViewModels.SearchViewModel
@{
    ViewData["Title"] = string.IsNullOrWhiteSpace(Model.Query) ? "Search" : $"Search Results for '{Model.Query}'";
}

<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,800;1,9..144,600;1,9..144,800&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>
    :root {
        --ns-cream: #faf6ef;
        --ns-sand: #f3ead9;
        --ns-peach: #f5d5b8;
        --ns-terracotta: #c97b5e;
        --ns-clay: #b86048;
        --ns-coffee: #4a3729;
        --ns-mocha: #6b4f3d;
        --ns-sage: #8fa68a;
        --ns-warm-gray: #a89684;
        --ns-soft-shadow: rgba(74, 55, 41, 0.08);
    }

    .ns-search {
        background: var(--ns-cream);
        color: var(--ns-coffee);
        font-family: 'Inter', -apple-system, sans-serif;
        min-height: 80vh;
        padding-bottom: 80px;
    }

        .ns-search .display-font {
            font-family: 'Fraunces', Georgia, serif;
            font-weight: 800;
            letter-spacing: -0.03em;
            line-height: 0.95;
        }

        .ns-search .mono {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            font-weight: 500;
        }

    /* ===== HEADER ===== */
    .ns-search-header {
        position: relative;
        background: linear-gradient(160deg, var(--ns-sand) 0%, var(--ns-peach) 100%);
        padding: 90px 0 80px;
        overflow: hidden;
        margin-bottom: 50px;
    }

        .ns-search-header::before {
            content: '';
            position: absolute;
            top: -120px;
            right: -80px;
            width: 380px;
            height: 380px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(201, 123, 94, 0.25) 0%, transparent 70%);
            filter: blur(40px);
        }

        .ns-search-header::after {
            content: '';
            position: absolute;
            bottom: -100px;
            left: -100px;
            width: 320px;
            height: 320px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(143, 166, 138, 0.18) 0%, transparent 70%);
            filter: blur(40px);
        }

    .ns-search-header-inner {
        position: relative;
        z-index: 2;
    }

    /* Breadcrumb */
    .ns-breadcrumb {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--ns-mocha);
        margin-bottom: 26px;
    }

        .ns-breadcrumb a {
            color: var(--ns-mocha);
            text-decoration: none;
            transition: color 0.3s ease;
        }

            .ns-breadcrumb a:hover {
                color: var(--ns-clay);
            }

        .ns-breadcrumb .sep {
            color: var(--ns-warm-gray);
            opacity: 0.6;
        }

        .ns-breadcrumb .current {
            color: var(--ns-coffee);
            font-weight: 600;
        }

    .ns-search-tag {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 18px;
        color: var(--ns-clay);
    }

        .ns-search-tag::before {
            content: '';
            width: 28px;
            height: 2px;
            background: currentColor;
        }

    .ns-search-title {
        font-size: clamp(2.6rem, 6vw, 5rem);
        color: var(--ns-coffee);
        margin: 0 0 18px;
        max-width: 900px;
    }

        .ns-search-title em {
            color: var(--ns-clay);
            font-style: italic;
        }

        .ns-search-title .quoted {
            color: var(--ns-clay);
            font-style: italic;
        }

    .ns-search-sub {
        font-size: 1.05rem;
        color: var(--ns-mocha);
        max-width: 580px;
        margin: 0 0 30px;
        line-height: 1.6;
    }

    /* Search bar */
    .ns-search-bar {
        display: flex;
        align-items: center;
        background: var(--ns-cream);
        border: 1.5px solid transparent;
        border-radius: 60px;
        padding: 6px 6px 6px 28px;
        max-width: 620px;
        box-shadow: 0 10px 30px rgba(74, 55, 41, 0.08);
        transition: all 0.3s ease;
    }

        .ns-search-bar:focus-within {
            border-color: var(--ns-terracotta);
            box-shadow: 0 12px 36px rgba(201, 123, 94, 0.18);
        }

        .ns-search-bar i.search-icon {
            color: var(--ns-warm-gray);
            font-size: 0.95rem;
            margin-right: 12px;
            transition: color 0.3s ease;
        }

        .ns-search-bar:focus-within i.search-icon {
            color: var(--ns-clay);
        }

        .ns-search-bar input {
            flex: 1;
            background: transparent;
            border: none;
            outline: none;
            color: var(--ns-coffee);
            font-family: 'Inter', sans-serif;
            font-size: 0.95rem;
            font-weight: 500;
            padding: 14px 0;
        }

            .ns-search-bar input::placeholder {
                color: var(--ns-warm-gray);
                font-weight: 400;
            }

        .ns-search-bar button {
            background: var(--ns-coffee);
            color: var(--ns-cream);
            border: none;
            border-radius: 50px;
            padding: 13px 28px;
            font-size: 0.82rem;
            font-weight: 600;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }

            .ns-search-bar button:hover {
                background: var(--ns-clay);
                transform: translateX(2px);
                box-shadow: 0 8px 20px rgba(184, 96, 72, 0.3);
            }

            .ns-search-bar button .arrow {
                transition: transform 0.3s ease;
            }

            .ns-search-bar button:hover .arrow {
                transform: translateX(4px);
            }

    /* Toolbar */
    .ns-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 36px;
        flex-wrap: wrap;
        gap: 16px;
    }

    .ns-results-count {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.78rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--ns-mocha);
        font-weight: 500;
    }

        .ns-results-count strong {
            color: var(--ns-clay);
            font-weight: 700;
        }

    .ns-active-filter {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--ns-sand);
        color: var(--ns-coffee);
        padding: 8px 16px 8px 18px;
        border-radius: 50px;
        font-size: 0.82rem;
        font-weight: 500;
        border: 1px solid rgba(74, 55, 41, 0.08);
    }

        .ns-active-filter .label {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.65rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--ns-mocha);
            margin-right: 4px;
        }

        .ns-active-filter a {
            width: 22px;
            height: 22px;
            border-radius: 50%;
            background: var(--ns-coffee);
            color: var(--ns-cream);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            font-size: 0.65rem;
            transition: all 0.25s ease;
        }

            .ns-active-filter a:hover {
                background: var(--ns-clay);
                transform: rotate(90deg);
            }

    /* ===== PRODUCT GRID ===== */
    .ns-product-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
        animation: ns-fade-in 0.5s ease-out;
    }

        /* Reset Bootstrap columns */
        .ns-product-grid > [class*="col-"],
        .ns-product-grid > div {
            padding: 0 !important;
            margin: 0 !important;
            max-width: 100% !important;
            width: 100% !important;
            flex: unset !important;
        }

        .ns-product-grid .card {
            background: #ffffff !important;
            border: none !important;
            border-radius: 24px !important;
            overflow: hidden;
            height: 100%;
            box-shadow: 0 8px 24px rgba(0,0,0,0.08);
            transition: all 0.3s ease;
        }

            .ns-product-grid .card:hover {
                transform: translateY(-8px);
                box-shadow: 0 18px 38px rgba(0,0,0,0.14);
            }

            .ns-product-grid .card-img-top,
            .ns-product-grid .card img {
                width: 100% !important;
                height: 260px !important;
                object-fit: cover !important;
                object-position: center !important;
                padding: 0 !important;
                background: #ffffff !important;
                display: block;
            }

        .ns-product-grid .card-body {
            padding: 24px 22px 22px !important;
            text-align: center;
        }

        .ns-product-grid .text-muted,
        .ns-product-grid .small {
            color: #6b4f3d !important;
            font-size: 0.78rem !important;
            font-weight: 700 !important;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            margin-bottom: 10px !important;
        }

        .ns-product-grid .card-title,
        .ns-product-grid h5,
        .ns-product-grid h6 {
            color: #222 !important;
            font-size: 1rem !important;
            font-weight: 700 !important;
            line-height: 1.35 !important;
            margin: 0 0 14px !important;
            min-height: 44px;
            display: block;
            white-space: normal !important;
            text-decoration: none !important;
        }

        .ns-product-grid a {
            text-decoration: none !important;
        }

        .ns-product-grid del,
        .ns-product-grid .old-price {
            color: #7a6a5d !important;
            margin-right: 10px;
        }

        .ns-product-grid .text-danger,
        .ns-product-grid .price,
        .ns-product-grid .new-price {
            color: #e6324b !important;
            font-weight: 800 !important;
            font-size: 1.15rem !important;
        }

        .ns-product-grid .btn {
            width: 100%;
            border-radius: 999px !important;
            padding: 11px 18px !important;
            font-weight: 800 !important;
            margin-top: 18px;
        }

        /* Product title fix */
        .ns-product-grid .card-body h5,
        .ns-product-grid .card-body h6,
        .ns-product-grid .card-body .card-title {
            display: block !important;
            width: 100% !important;
            min-height: 48px !important;
            margin: 12px 0 24px !important;
            line-height: 1.4 !important;
            font-size: 1rem !important;
            font-weight: 700 !important;
            text-align: center !important;
            white-space: normal !important;
            overflow: visible !important;
            position: static !important;
            transform: none !important;
        }

        .ns-product-grid .card-body a {
            display: block !important;
            line-height: 1.4 !important;
        }

    .ns-product-name {
        font-size: 1rem;
        font-weight: 700;
        line-height: 1.4;
        color: #222;
        margin: 10px 0 18px;
        min-height: 45px;
        text-align: center;
    }

    @@keyframes ns-fade-in {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Empty state */
    .ns-empty {
        text-align: center;
        padding: 80px 30px;
        background: var(--ns-sand);
        border-radius: 28px;
        border: 1.5px dashed rgba(74, 55, 41, 0.15);
    }

    .ns-empty-icon {
        width: 96px;
        height: 96px;
        border-radius: 50%;
        background: var(--ns-cream);
        color: var(--ns-clay);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        margin-bottom: 26px;
        box-shadow: 0 10px 30px rgba(74, 55, 41, 0.08);
    }

    .ns-empty-title {
        font-family: 'Fraunces', serif;
        font-weight: 800;
        font-style: italic;
        font-size: 2.2rem;
        color: var(--ns-coffee);
        margin: 0 0 14px;
        letter-spacing: -0.02em;
    }

    .ns-empty-text {
        font-size: 1rem;
        color: var(--ns-mocha);
        margin: 0 auto 30px;
        max-width: 480px;
        line-height: 1.6;
    }

        .ns-empty-text .term {
            color: var(--ns-coffee);
            font-weight: 600;
        }

    .ns-empty-actions {
        display: inline-flex;
        gap: 12px;
        flex-wrap: wrap;
        justify-content: center;
    }

    .ns-btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: var(--ns-coffee);
        color: var(--ns-cream);
        padding: 14px 28px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.85rem;
        letter-spacing: 0.02em;
        text-decoration: none;
        transition: all 0.35s ease;
    }

        .ns-btn-primary:hover {
            background: var(--ns-clay);
            color: var(--ns-cream);
            transform: translateY(-2px);
            box-shadow: 0 10px 24px rgba(184, 96, 72, 0.3);
        }

    .ns-btn-ghost {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: var(--ns-cream);
        color: var(--ns-coffee);
        padding: 14px 28px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.85rem;
        text-decoration: none;
        border: 1.5px solid rgba(74, 55, 41, 0.15);
        transition: all 0.35s ease;
    }

        .ns-btn-ghost:hover {
            background: var(--ns-sand);
            color: var(--ns-coffee);
            transform: translateY(-2px);
        }

    /* Idle state (no query yet) */
    .ns-idle {
        text-align: center;
        padding: 70px 30px;
    }

        .ns-idle h3 {
            font-family: 'Fraunces', serif;
            font-weight: 800;
            font-style: italic;
            font-size: 1.8rem;
            color: var(--ns-coffee);
            margin: 0 0 10px;
        }

        .ns-idle p {
            font-size: 0.95rem;
            color: var(--ns-mocha);
            margin: 0;
        }

    /* Responsive */
    @@media (max-width: 1100px) {
        .ns-product-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @@media (max-width: 800px) {
        .ns-product-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 18px;
        }

        .ns-search-header {
            padding: 70px 0 60px;
            margin-bottom: 36px;
        }
    }

    @@media (max-width: 576px) {
        .ns-product-grid {
            grid-template-columns: 1fr;
        }

        .ns-search-bar {
            flex-wrap: wrap;
            padding: 14px;
            border-radius: 22px;
        }

            .ns-search-bar input {
                width: 100%;
                padding: 8px 0;
            }

            .ns-search-bar button {
                width: 100%;
                justify-content: center;
            }
    }
</style>

<div class="ns-search">

    @* ===== HEADER ===== *@
    <section class="ns-search-header">
        <div class="container ns-search-header-inner">

            <nav class="ns-breadcrumb">
                <a asp-controller="Home" asp-action="Index"><i class="fa fa-home me-1"></i> Home</a>
                <span class="sep">/</span>
                <span class="current">Search</span>
            </nav>

            <div class="ns-search-tag mono">Search</div>

            @if (string.IsNullOrWhiteSpace(Model.Query))
            {
                <h1 class="ns-search-title display-font">
                    What are you <em>looking for?</em>
                </h1>
                <p class="ns-search-sub">
                    Discover premium athletic footwear designed for performance. Search by name,
                    brand, or category.
                </p>
            }
            else
            {
                <h1 class="ns-search-title display-font">
                    Results for <span class="quoted">"@Model.Query"</span>
                </h1>
                <p class="ns-search-sub">
                    @Model.Products.Count matching @(Model.Products.Count == 1 ? "item" : "items")
                    found across our catalog.
                </p>
            }

            <form asp-controller="Search" asp-action="Index" method="get" class="ns-search-bar">
                <i class="fa fa-search search-icon"></i>
                <input type="text" name="q" value="@Model.Query"
                       placeholder="Search shoes, brands, or categories..." autocomplete="off" />
                <button type="submit">
                    Search
                    <span class="arrow">→</span>
                </button>
            </form>

        </div>
    </section>

    <div class="container">

        @if (string.IsNullOrWhiteSpace(Model.Query))
        {
            <div class="ns-idle">
                <h3>Start by searching above.</h3>
                <p>Type a keyword to see what matches in our catalog.</p>
            </div>
        }
        else if (Model.Products.Any())
        {
            <div class="ns-toolbar">
                <div class="ns-results-count">
                    <strong>@Model.Products.Count</strong> @(Model.Products.Count == 1 ? "Result" : "Results") Found
                </div>
                <div class="ns-active-filter">
                    <span class="label">Searching</span>
                    <span>"@Model.Query"</span>
                    <a asp-controller="Products" asp-action="Index" title="Clear search">
                        <i class="fa fa-times"></i>
                    </a>
                </div>
            </div>

            <div class="ns-product-grid">
                @foreach (var product in Model.Products)
                {
                    <partial name="_ProductCard" model="product" />
                }
            </div>
        }
        else
        {
            <div class="ns-empty">
                <div class="ns-empty-icon">
                    <i class="fa fa-search"></i>
                </div>
                <h2 class="ns-empty-title">No matches found.</h2>
                <p class="ns-empty-text">
                    We couldn't find anything matching <span class="term">"@Model.Query"</span>.
                    Try checking your spelling, using fewer keywords, or browsing the full catalog.
                </p>
                <div class="ns-empty-actions">
                    <a asp-controller="Products" asp-action="Index" class="ns-btn-primary">
                        <i class="fa fa-arrow-left"></i>
                        Browse All Products
                    </a>
                    <a asp-controller="Home" asp-action="Index" class="ns-btn-ghost">
                        Back Home
                    </a>
                </div>
            </div>
        }

    </div>
</div>