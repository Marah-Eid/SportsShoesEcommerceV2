@using Microsoft.AspNetCore.Identity
@using SportsShoesEcommerce.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav ms-auto align-items-center">
    @if (SignInManager.IsSignedIn(User))
    {
        // Get the logged-in user's details to show their name
        var user = await UserManager.GetUserAsync(User);

        <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle text-dark d-flex align-items-center p-0" href="#" id="profileDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <img src="@(user?.ProfileImage ?? "/admin/img/undraw_profile.svg")" class="rounded-circle me-2 border shadow-sm" style="width: 40px; height: 40px; object-fit: cover;" alt="Profile">
                <span class="fw-bold d-none d-md-inline">@(user?.FullName ?? "My Account")</span>
            </a>

            <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-3" aria-labelledby="profileDropdown" style="border-radius: 12px; min-width: 220px;">

                <li><a class="dropdown-item py-2 fw-bold text-dark" asp-area="Identity" asp-page="/Account/Manage/Index"><i class="fa fa-user-circle me-2 text-muted"></i> My Profile</a></li>

                <li><a class="dropdown-item py-2 fw-bold text-dark" asp-area="" asp-controller="Orders" asp-action="MyOrders"><i class="fa fa-box-open me-3 text-muted"></i> My Orders</a></li>

                <li><a class="dropdown-item py-2 fw-bold text-dark" asp-area="" asp-controller="Wishlist" asp-action="Index"><i class="fa fa-heart me-3 text-danger"></i> My Wishlist</a></li>

                <li><a class="dropdown-item py-2 fw-bold text-dark" asp-area="" asp-controller="Testimonials" asp-action="Create"><i class="fa fa-star me-3 text-warning"></i> Rate Us</a></li>

                <li><hr class="dropdown-divider my-2"></li>

                <li>
                    <form class="form-inline m-0" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/Identity/Account/Login">
                        <button type="submit" class="dropdown-item py-2 text-danger fw-bold transition-hover" style="background: transparent; border: none; width: 100%; text-align: left;">
                            <i class="fa fa-sign-out-alt me-2"></i> Logout
                        </button>
                    </form>
                </li>
            </ul>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-dark fw-bold me-3 text-hover-brand" asp-area="Identity" asp-page="/Account/Register">
                <i class="fa fa-user-plus me-1"></i> Register
            </a>
        </li>
        <li class="nav-item">
            <a class="btn btn-dark rounded-pill px-4 py-2 fw-bold shadow-sm transition-hover" asp-area="Identity" asp-page="/Account/Login">
                <i class="fa fa-sign-in-alt me-1"></i> Login
            </a>
        </li>
    }
</ul>