@{
    ViewData["Title"] = "Rate Us";
}

<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,800;1,9..144,600;1,9..144,800&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>
    :root {
        --ns-cream: #faf6ef;
        --ns-sand: #f3ead9;
        --ns-peach: #f5d5b8;
        --ns-terracotta: #c97b5e;
        --ns-clay: #b86048;
        --ns-coffee: #4a3729;
        --ns-mocha: #6b4f3d;
        --ns-sage: #8fa68a;
        --ns-warm-gray: #a89684;
        --ns-soft-shadow: rgba(74, 55, 41, 0.08);
    }

    .ns-rate {
        background: var(--ns-cream);
        color: var(--ns-coffee);
        font-family: 'Inter', -apple-system, sans-serif;
        min-height: 100vh;
        padding: 100px 0 60px;
        position: relative;
        overflow-x: hidden;
    }

        .ns-rate::before {
            content: '';
            position: absolute;
            top: 5%;
            right: -100px;
            width: 380px;
            height: 380px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(201, 123, 94, 0.12) 0%, transparent 70%);
            filter: blur(50px);
            pointer-events: none;
        }

        .ns-rate::after {
            content: '';
            position: absolute;
            bottom: 5%;
            left: -100px;
            width: 320px;
            height: 320px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(143, 166, 138, 0.12) 0%, transparent 70%);
            filter: blur(50px);
            pointer-events: none;
        }

        .ns-rate .display-font {
            font-family: 'Fraunces', Georgia, serif;
            font-weight: 800;
            letter-spacing: -0.03em;
            line-height: 0.95;
        }

    .ns-rate-wrap {
        max-width: 540px;
        margin: 0 auto;
        padding: 0 24px;
        position: relative;
        z-index: 2;
    }

    .ns-rate-card {
        background: var(--ns-cream);
        border: 1px solid rgba(74, 55, 41, 0.08);
        border-radius: 32px;
        padding: 48px 44px;
        box-shadow: 0 30px 80px rgba(74, 55, 41, 0.12);
        position: relative;
        overflow: hidden;
    }

        .ns-rate-card::before {
            content: '"';
            position: absolute;
            top: -80px;
            right: -20px;
            font-family: 'Fraunces', serif;
            font-style: italic;
            font-size: 18rem;
            line-height: 1;
            color: var(--ns-clay);
            opacity: 0.06;
            font-weight: 800;
            pointer-events: none;
        }

    .ns-rate-head {
        text-align: center;
        margin-bottom: 36px;
        position: relative;
        z-index: 2;
    }

    .ns-rate-tag {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 16px;
        color: var(--ns-clay);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        font-weight: 500;
    }

        .ns-rate-tag::before,
        .ns-rate-tag::after {
            content: '';
            width: 24px;
            height: 2px;
            background: currentColor;
        }

    .ns-rate-title {
        font-size: 2.2rem;
        color: var(--ns-coffee);
        margin: 0 0 10px;
    }

        .ns-rate-title em {
            color: var(--ns-clay);
            font-style: italic;
        }

    .ns-rate-sub {
        font-size: 0.95rem;
        color: var(--ns-mocha);
        margin: 0;
    }

    .ns-rate-error {
        background: rgba(184, 96, 72, 0.08);
        border-left: 3px solid var(--ns-clay);
        border-radius: 10px;
        padding: 12px 18px;
        color: var(--ns-clay);
        font-size: 0.85rem;
        font-weight: 500;
        text-align: center;
        margin-bottom: 20px;
        position: relative;
        z-index: 2;
    }

        .ns-rate-error:empty {
            display: none;
        }

    .ns-rate-form {
        position: relative;
        z-index: 2;
    }

    .ns-rate-label {
        display: block;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--ns-mocha);
        text-align: center;
        margin-bottom: 16px;
        font-weight: 600;
    }

    /* Star rating */
    .ns-stars {
        display: flex;
        flex-direction: row-reverse;
        justify-content: center;
        gap: 10px;
        margin-bottom: 34px;
    }

        .ns-stars input {
            display: none;
        }

        .ns-stars label {
            font-size: 2.4rem;
            color: rgba(74, 55, 41, 0.15);
            cursor: pointer;
            transition: all 0.25s ease;
            margin: 0;
        }

            .ns-stars input:checked ~ label,
            .ns-stars label:hover,
            .ns-stars label:hover ~ label {
                color: var(--ns-clay);
                transform: scale(1.1);
            }

    /* Textarea */
    .ns-rate-textarea {
        width: 100%;
        background: var(--ns-sand);
        border: 1.5px solid transparent;
        border-radius: 18px;
        padding: 18px 22px;
        font-size: 0.95rem;
        color: var(--ns-coffee);
        font-family: 'Inter', sans-serif;
        font-weight: 500;
        resize: vertical;
        min-height: 130px;
        transition: all 0.3s ease;
        margin-bottom: 22px;
    }

        .ns-rate-textarea:focus {
            outline: none;
            border-color: var(--ns-terracotta);
            background: var(--ns-cream);
            box-shadow: 0 0 0 4px rgba(201, 123, 94, 0.12);
        }

        .ns-rate-textarea::placeholder {
            color: var(--ns-warm-gray);
            font-weight: 400;
        }

    /* Submit */
    .ns-rate-submit {
        width: 100%;
        background: var(--ns-coffee);
        color: var(--ns-cream);
        border: none;
        border-radius: 50px;
        padding: 17px 28px;
        font-weight: 600;
        font-size: 0.9rem;
        letter-spacing: 0.02em;
        font-family: 'Inter', sans-serif;
        cursor: pointer;
        transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
    }

        .ns-rate-submit:hover {
            background: var(--ns-clay);
            transform: translateY(-3px);
            box-shadow: 0 14px 30px rgba(184, 96, 72, 0.3);
        }

        .ns-rate-submit .arrow {
            transition: transform 0.3s ease;
        }

        .ns-rate-submit:hover .arrow {
            transform: translateX(6px);
        }

    /* Back link */
    .ns-rate-back {
        text-align: center;
        margin-top: 28px;
    }

        .ns-rate-back a {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.72rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--ns-mocha);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-weight: 500;
            transition: all 0.3s ease;
        }

            .ns-rate-back a:hover {
                color: var(--ns-clay);
                gap: 14px;
            }

    @@media (max-width: 576px) {
        .ns-rate {
            padding: 80px 0 40px;
        }

        .ns-rate-card {
            padding: 36px 28px;
            border-radius: 24px;
        }

        .ns-rate-title {
            font-size: 1.8rem;
        }

        .ns-stars label {
            font-size: 2rem;
        }
    }
</style>

<div class="ns-rate">
    <div class="ns-rate-wrap">

        <div class="ns-rate-card">

            <div class="ns-rate-head">
                <div class="ns-rate-tag">Share Your Story</div>
                <h2 class="ns-rate-title display-font">Rate your <em>experience.</em></h2>
                <p class="ns-rate-sub">We'd love to hear your thoughts.</p>
            </div>

            <div asp-validation-summary="ModelOnly" class="ns-rate-error"></div>

            <form asp-controller="Testimonials" asp-action="Create" method="post" class="ns-rate-form">

                <span class="ns-rate-label">How would you rate us?</span>
                <div class="ns-stars">
                    <input type="radio" id="star5" name="rating" value="5" required />
                    <label for="star5" class="fa fa-star"></label>
                    <input type="radio" id="star4" name="rating" value="4" />
                    <label for="star4" class="fa fa-star"></label>
                    <input type="radio" id="star3" name="rating" value="3" />
                    <label for="star3" class="fa fa-star"></label>
                    <input type="radio" id="star2" name="rating" value="2" />
                    <label for="star2" class="fa fa-star"></label>
                    <input type="radio" id="star1" name="rating" value="1" />
                    <label for="star1" class="fa fa-star"></label>
                </div>

                <textarea class="ns-rate-textarea" id="content" name="content" rows="4"
                          placeholder="Tell us about your new gear..." required></textarea>

                <button type="submit" class="ns-rate-submit">
                    Submit Review
                    <span class="arrow">→</span>
                </button>

            </form>
        </div>

        <div class="ns-rate-back">
            <a asp-controller="Home" asp-action="Index">
                <i class="fa fa-arrow-left"></i> Back to Home
            </a>
        </div>

    </div>
</div>